@{
	Layout = "~/Views/Shared/_LayoutMophyAdmin.cshtml";
	ViewData["Title"] = "<<Put your different title string value here for each page>>";
}
<div class="content-body default-height">
	<div class="container-fluid">
		<div class="page-titles">
			<ol class="breadcrumb">
				<li class="breadcrumb-item"><a href="javascript:void(0)"> Plugins</a></li>
				<li class="breadcrumb-item active"><a href="javascript:void(0)">Light Gallery</a></li>
			</ol>
		</div>
		<div class="row">
			<div class="col-lg-12">
				<div class="card">
					<div class="card-header">
						<h4 class="card-title">Light Gallery</h4>
					</div>
					<div class="card-body pb-1">
						<div id="lightgallery" class="row">
							<a href="../mophy/admin/images/big/img1.jpg" data-src="../mophy/admin/images/big/img1.jpg" class=" lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img1.jpg" alt="" class="w-100 rounded">
							</a>
							<a href="../mophy/admin/images/big/img2.jpg" data-src="../mophy/admin/images/big/img2.jpg" class="lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img2.jpg" alt="" class="w-100 rounded">
							</a>
							<a href="../mophy/admin/images/big/img3.jpg" data-src="../mophy/admin/images/big/img3.jpg" class="lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img3.jpg" alt="" class="w-100 rounded">
							</a>
							<a href="../mophy/admin/images/big/img4.jpg" data-src="../mophy/admin/images/big/img4.jpg" class="lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img4.jpg" alt="" class="w-100 rounded">
							</a>
							<a href="../mophy/admin/images/big/img5.jpg" data-src="../mophy/admin/images/big/img5.jpg" class="lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img5.jpg" alt="" class="w-100 rounded">
							</a>
							<a href="../mophy/admin/images/big/img6.jpg" data-src="../mophy/admin/images/big/img6.jpg" class="lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img6.jpg" alt="" class="w-100 rounded">
							</a>
							<a href="../mophy/admin/images/big/img7.jpg" data-src="../mophy/admin/images/big/img7.jpg" class="lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img7.jpg" alt="" class="w-100 rounded">
							</a>
							<a href="../mophy/admin/images/big/img8.jpg" data-src="../mophy/admin/images/big/img8.jpg" class="lg-item col-lg-3 col-md-6 mb-4">
								<img src="~/mophy/admin/images/big/img8.jpg" alt="" class="w-100 rounded">
							</a>
						</div>
					</div>
				</div>
				<!-- /# card -->
			</div>
		</div>
	</div>
</div>

@section Mophy_style
{
	<link href="~/mophy/admin/vendor/lightgallery/dist/css/lightgallery.css" rel="stylesheet">
	<link href="~/mophy/admin/vendor/lightgallery/dist/css/lg-thumbnail.css" rel="stylesheet">
	<link href="~/mophy/admin/vendor/lightgallery/dist/css/lg-zoom.css" rel="stylesheet">
}

@section Mophy_script
{
	<!--**********************************
		Scripts
	***********************************-->
	<!-- Required vendors -->
	<script src="~/mophy/admin/vendor/global/global.min.js"></script>
	<script src="~/mophy/admin/vendor/bootstrap-select/dist/js/bootstrap-select.min.js"></script>

	<!-- Light Gallery -->
	<script src="~/mophy/admin/vendor/lightgallery/dist/lightgallery.min.js"></script>
	<script src="~/mophy/admin/vendor/lightgallery/dist/plugins/thumbnail/lg-thumbnail.min.js"></script>
	<script src="~/mophy/admin/vendor/lightgallery/dist/plugins/zoom/lg-zoom.min.js"></script>
	<script src="~/mophy/admin/js/custom.min.js"></script>
	<script src="~/mophy/admin/js/deznav-init.js"></script>
	
	
}