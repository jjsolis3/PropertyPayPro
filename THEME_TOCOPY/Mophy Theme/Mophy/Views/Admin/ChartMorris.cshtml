@{
	Layout = "~/Views/Shared/_LayoutMophyAdmin.cshtml";
	ViewData["Title"] = "<<Put your different title string value here for each page>>";
}
<div class="content-body default-height">
	<div class="container-fluid">
		<div class="page-titles">
			<ol class="breadcrumb">
				<li class="breadcrumb-item"><a href="javascript:void(0)">Charts</a></li>
				<li class="breadcrumb-item active"><a href="javascript:void(0)">Morris</a></li>
			</ol>
		</div>
		<!-- row -->

		<div class="row">
			<div class="col-12">
				<div class="row">
					<div class="col-xl-6 col-lg-6">
						<div class="card">
							<div class="card-header">
								<h4 class="card-title">Donught Chart</h4>
							</div>
							<div class="card-body">
								<div id="morris_donught" class="morris_chart_height"></div>
							</div>
						</div>
					</div>
					<div class="col-xl-6 col-lg-6">
						<div class="card">
							<div class="card-header">
								<h4 class="card-title">Line Chart</h4>
							</div>
							<div class="card-body p-0">
								<div id="morris_line" class="morris_chart_height"></div>
							</div>
						</div>
					</div>
					<div class="col-xl-6 col-lg-6">
						<div class="card">
							<div class="card-header">
								<h4 class="card-title">Bar Chart</h4>
							</div>
							<div class="card-body">
								<div id="morris_bar" class="morris_chart_height"></div>
							</div>
						</div>
					</div>
					<div class="col-xl-6 col-lg-6">
						<div class="card">
							<div class="card-header">
								<h4 class="card-title">Line Chart</h4>
							</div>
							<div class="card-body">
								<div id="line_chart_2" class="morris_chart_height"></div>
							</div>
						</div>
					</div>
					<div class="col-xl-6 col-lg-6">
						<div class="card">
							<div class="card-header">
								<h4 class="card-title">Bar Chart</h4>
							</div>
							<div class="card-body">
								<div id="morris_bar_stalked" class="morris_chart_height"></div>
							</div>
						</div>
					</div>
					<div class="col-xl-6 col-lg-6">
						<div class="card">
							<div class="card-header">
								<h4 class="card-title">Area Chart</h4>
							</div>
							<div class="card-body">
								<div id="morris_area" class="morris_chart_height"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Mophy_style
{
	
}

@section Mophy_script
{
	<!--**********************************
		Scripts
	***********************************-->
	<!-- Required vendors -->
	<script src="~/mophy/admin/vendor/global/global.min.js"></script>
	<script src="~/mophy/admin/vendor/bootstrap-select/dist/js/bootstrap-select.min.js"></script>

	<!-- Chart Morris plugin files -->
	<script src="~/mophy/admin/vendor/raphael/raphael.min.js"></script>
	<script src="~/mophy/admin/vendor/morris/morris.min.js"></script>
	<script src="~/mophy/admin/js/plugins-init/morris-init.js"></script>
	<script src="~/mophy/admin/js/custom.min.js"></script>
	<script src="~/mophy/admin/js/deznav-init.js"></script>
	
	
}