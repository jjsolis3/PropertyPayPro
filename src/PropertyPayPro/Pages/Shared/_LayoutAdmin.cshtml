@inject PropertyPayPro.Services.AppSettingsService AppSettings
@{
    var appSettings = await AppSettings.GetAsync();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - @appSettings.AppName</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/img/brand/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/img/brand/favicon/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/img/brand/favicon/apple-touch-icon.png">
    <link rel="manifest" href="/img/brand/favicon/site.webmanifest">

    <link href="~/mophy/admin/vendor/bootstrap-select/dist/css/bootstrap-select.min.css" rel="stylesheet">
    <link href="~/mophy/admin/vendor/datatables/css/jquery.dataTables.min.css" rel="stylesheet">
    @RenderSection("Styles", false)
    <link class="main-css" href="~/mophy/admin/css/style.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
    <style>
        :root {
            --pps-primary: @appSettings.PrimaryColor;
            --pps-accent: @appSettings.AccentColor;
        }
    </style>
    <script>
        // Restore sidebar collapsed state before the sidebar renders,
        // otherwise the icon strip vs full-text flashes on every load.
        // If the user has no stored preference yet, default to
        // collapsed on mobile so a 16.5rem sidebar doesn't crush the
        // content column on a phone.
        (function () {
            try {
                var stored = localStorage.getItem('pps-sidebar-collapsed');
                var collapsed;
                if (stored === '1') collapsed = true;
                else if (stored === '0') collapsed = false;
                else collapsed = window.innerWidth < 992;
                if (collapsed) {
                    document.documentElement.classList.add('menu-toggle');
                }
            } catch (e) { /* localStorage unavailable — ignore */ }
        })();
    </script>
</head>
<body>
    <div id="preloader">
        <div class="sk-three-bounce">
            <div class="sk-child sk-bounce1"></div>
            <div class="sk-child sk-bounce2"></div>
            <div class="sk-child sk-bounce3"></div>
        </div>
    </div>

    <div id="main-wrapper">
        <partial name="_NavHeader" />
        <partial name="_HeaderAdmin" />
        @{
            var sidebarPartial = ViewData["IsPortal"] is true ? "_SidebarPortal" : "_Sidebar";
        }
        <partial name="@sidebarPartial" />

        <div class="content-body default-height">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </div>

        <partial name="_FooterAdmin" />
    </div>

    <script src="~/mophy/admin/vendor/global/global.min.js"></script>
    <script src="~/mophy/admin/vendor/bootstrap-select/dist/js/bootstrap-select.min.js"></script>
    <script src="~/mophy/admin/vendor/chart-js/chart.bundle.min.js"></script>
    <script src="~/mophy/admin/vendor/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/mophy/admin/js/custom.min.js"></script>
    <script src="~/mophy/admin/js/deznav-init.js"></script>
    <script src="~/js/toasts.js"></script>
    <script src="~/js/datatables-init.js"></script>
    <script src="~/js/sidebar-persist.js"></script>
    @RenderSection("Scripts", false)
</body>
</html>
