@using Microsoft.AspNetCore.Identity
@using PropertyPayPro.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ApplicationUser? currentUser = null;
    if (SignInManager.IsSignedIn(User))
    {
        currentUser = await UserManager.GetUserAsync(User);
    }
    var displayName = currentUser?.DisplayName ?? User.Identity?.Name ?? "User";
    var hasAvatar = !string.IsNullOrWhiteSpace(currentUser?.AvatarStorageKey);
    var avatarUrl = hasAvatar
        ? Url.Page("/Account/Manage/Avatar", new { area = "Identity" })
        : null;
    var initials = string.Concat(displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(s => char.ToUpper(s[0])));
}

<div class="header">
    <div class="header-content">
        <nav class="navbar navbar-expand">
            <div class="collapse navbar-collapse justify-content-between">
                <div class="header-left">
                    <div class="dashboard_bar">
                        @ViewData["Title"]
                    </div>
                </div>
                <ul class="navbar-nav header-right">
                    @if (currentUser is not null)
                    {
                        <li class="nav-item dropdown header-profile">
                            <a class="nav-link" href="javascript:void(0)" role="button" data-bs-toggle="dropdown">
                                <div class="header-info">
                                    <span class="text-black">Hello, <strong>@displayName</strong></span>
                                    <p class="fs-12 mb-0">Admin</p>
                                </div>
                                @if (hasAvatar)
                                {
                                    <img src="@avatarUrl" width="32" height="32" alt="@displayName"
                                         class="rounded-circle" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold"
                                          style="width: 32px; height: 32px; font-size: 0.85rem;">@initials</span>
                                }
                            </a>
                            <div class="dropdown-menu dropdown-menu-end">
                                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="dropdown-item ai-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="text-primary" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                    <span class="ms-2">Profile</span>
                                </a>
                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" class="dropdown-item ai-icon p-0">
                                    <button type="submit" class="btn btn-link p-2 text-decoration-none text-start w-100">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="text-danger" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                                        <span class="ms-2">Logout</span>
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a asp-area="Identity" asp-page="/Account/Login" class="nav-link">Login</a></li>
                    }
                </ul>
            </div>
        </nav>
    </div>
</div>
