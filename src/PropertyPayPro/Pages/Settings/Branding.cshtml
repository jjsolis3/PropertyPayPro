@page
@model PropertyPayPro.Pages.Settings.BrandingModel
@{
    ViewData["Title"] = "Settings — Branding";
    ViewData["SettingsTab"] = "branding";
}

<h1 class="h3 mb-3">Settings</h1>
<partial name="_SettingsNav" />

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="post" enctype="multipart/form-data">
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header"><h4 class="card-title mb-0">Identity</h4></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Input.AppName" class="form-label">App name</label>
                        <input asp-for="Input.AppName" class="form-control" />
                        <small class="text-muted">Used in the browser tab title and email subjects.</small>
                        <span asp-validation-for="Input.AppName" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.PrimaryColor" class="form-label">Primary color</label>
                            <div class="input-group">
                                <input asp-for="Input.PrimaryColor" type="color" class="form-control form-control-color" style="max-width: 4rem;" />
                                <input asp-for="Input.PrimaryColor" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.AccentColor" class="form-label">Accent color</label>
                            <div class="input-group">
                                <input asp-for="Input.AccentColor" type="color" class="form-control form-control-color" style="max-width: 4rem;" />
                                <input asp-for="Input.AccentColor" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h4 class="card-title mb-0">Logos</h4></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Wordmark (sidebar expanded)</label>
                            <div class="border rounded p-3 text-center bg-light mb-2" style="min-height: 90px;">
                                @if (!string.IsNullOrEmpty(Model.Current.LogoStorageKey))
                                {
                                    <img src="?handler=Logo&which=main" alt="Custom logo" style="max-height: 60px;" />
                                }
                                else
                                {
                                    <img src="/img/brand/PPS_Logo_Main.png" alt="Default" style="max-height: 60px;" />
                                    <div><small class="text-muted">Default (no custom upload)</small></div>
                                }
                            </div>
                            <input type="file" name="logoMain" accept="image/png,image/jpeg,image/webp" class="form-control" />
                            @if (!string.IsNullOrEmpty(Model.Current.LogoStorageKey))
                            {
                                <button type="submit" formaction="?handler=ClearLogo&which=main" class="btn btn-sm btn-outline-danger mt-2"
                                        onclick="return confirm('Restore default wordmark?');">Restore default</button>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Compact mark (sidebar collapsed)</label>
                            <div class="border rounded p-3 text-center bg-light mb-2" style="min-height: 90px;">
                                @if (!string.IsNullOrEmpty(Model.Current.LogoSmallStorageKey))
                                {
                                    <img src="?handler=Logo&which=small" alt="Custom compact" style="max-height: 60px;" />
                                }
                                else
                                {
                                    <img src="/img/brand/PPS_Logo_SM.png" alt="Default" style="max-height: 60px;" />
                                    <div><small class="text-muted">Default (no custom upload)</small></div>
                                }
                            </div>
                            <input type="file" name="logoSmall" accept="image/png,image/jpeg,image/webp" class="form-control" />
                            @if (!string.IsNullOrEmpty(Model.Current.LogoSmallStorageKey))
                            {
                                <button type="submit" formaction="?handler=ClearLogo&which=small" class="btn btn-sm btn-outline-danger mt-2"
                                        onclick="return confirm('Restore default compact mark?');">Restore default</button>
                            }
                        </div>
                    </div>
                    <small class="text-muted d-block mt-3">
                        PNG, JPG, or WebP. Wordmark renders ~150px wide; compact mark ~45px square.
                        Files are stored under <code>/app/uploads/branding/</code> on the Coolify volume.
                    </small>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-header"><h4 class="card-title mb-0">Preview</h4></div>
                <div class="card-body">
                    <div class="mb-2">
                        <small class="text-muted">Primary</small>
                        <div class="rounded" id="previewPrimary"
                             style="background:@Model.Current.PrimaryColor; height:30px;"></div>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted">Accent</small>
                        <div class="rounded" id="previewAccent"
                             style="background:@Model.Current.AccentColor; height:30px;"></div>
                    </div>
                    <small class="text-muted d-block mt-3">
                        Colors will be applied to chrome and PDF headers on next deploy.
                        (Live theme swap is on the roadmap.)
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Branding</button>
        <a asp-page="Branding" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const pColor = document.querySelectorAll('input[name="Input.PrimaryColor"]');
            const aColor = document.querySelectorAll('input[name="Input.AccentColor"]');
            const previewP = document.getElementById('previewPrimary');
            const previewA = document.getElementById('previewAccent');
            function sync(inputs, target) {
                inputs.forEach(el => el.addEventListener('input', e => {
                    inputs.forEach(other => { if (other !== e.target) other.value = e.target.value; });
                    if (target) target.style.background = e.target.value;
                }));
            }
            sync(pColor, previewP);
            sync(aColor, previewA);
        })();
    </script>
}
