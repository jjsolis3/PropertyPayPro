@page "{id:int}"
@model PropertyPayPro.Pages.Leases.DetailsModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "Lease";
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
    var isActive = Model.Lease!.StartDate <= today && (Model.Lease.IsMonthToMonth || Model.Lease.EndDate >= today);
    var badges = new List<DetailHeaderBadge>();
    badges.Add(isActive
        ? new DetailHeaderBadge { Text = "Active", Color = "success" }
        : new DetailHeaderBadge { Text = "Ended", Color = "secondary" });
    if (Model.Lease.IsMonthToMonth)
        badges.Add(new() { Text = "Month-to-month", Color = "info" });
    if (Model.CurrentBalance > 0)
        badges.Add(new() { Text = $"Balance: {Model.CurrentBalance:C}", Color = "danger" });
    var subtitle = $"{Model.Lease.Property!.Name} • {Model.Lease.TenantNames}";
    var paymentCount = Model.Lease.Payments.Count;
    var docCount = Model.Lease.Documents.Count;
    var pdfCount = Model.GeneratedDocs.Count;
}

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap align-items-center gap-3">
        <div class="flex-grow-1">
            <partial name="_DetailHeader" model="@(new DetailHeaderModel {
                Title = $"Lease #{Model.Lease.Id}",
                Subtitle = subtitle,
                IconClass = "flaticon-381-notepad",
                IconColor = "primary",
                Badges = badges
            })" />
        </div>
        <div class="flex-shrink-0">
            <a asp-page="/Reports/Statement" asp-route-leaseId="@Model.Lease.Id" class="btn btn-outline-info">View Statement</a>
            <a asp-page="/Payments/Create" asp-route-leaseId="@Model.Lease.Id" class="btn btn-success">Record Payment</a>
            <a asp-page="Edit" asp-route-id="@Model.Lease.Id" class="btn btn-primary">Edit</a>
            <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Monthly Rent", Value = Model.Lease.MonthlyRent.ToString("C"),
        Color = "primary", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Total Billed", Value = Model.TotalBilled.ToString("C"),
        SubText = $"{Model.Charges.Count} charge(s)",
        Color = "info", Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Total Paid", Value = Model.TotalPaid.ToString("C"),
        Color = "success", Icon = "flaticon-381-notepad" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Balance", Value = Model.CurrentBalance.ToString("C"),
        SubText = $"{Model.UnpaidCount} unpaid",
        Color = Model.CurrentBalance > 0 ? "danger" : "success",
        Icon = "flaticon-381-warning" })" />
</div>

<div class="card">
    <div class="card-body p-0">
        <ul class="nav nav-tabs nav-fill" id="leaseTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-overview" type="button" role="tab">Overview</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-unpaid" type="button" role="tab">
                    Unpaid Bills <span class="badge @(Model.UnpaidCount > 0 ? "bg-danger" : "bg-success") ms-1">@Model.UnpaidCount</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-bills" type="button" role="tab">
                    Bill History <span class="badge bg-secondary ms-1">@Model.Charges.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-payments" type="button" role="tab">
                    Payments <span class="badge bg-secondary ms-1">@paymentCount</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-docs" type="button" role="tab">
                    Documents <span class="badge bg-secondary ms-1">@docCount</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-pdfs" type="button" role="tab">
                    Generated PDFs <span class="badge bg-secondary ms-1">@pdfCount</span>
                </button>
            </li>
        </ul>

        <div class="tab-content p-3">
            <div class="tab-pane fade show active" id="tab-overview" role="tabpanel">
                <h5 class="mb-3">Lease Terms</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Property</dt>
                    <dd class="col-sm-9">
                        <a asp-page="/Properties/Details" asp-route-id="@Model.Lease.PropertyId">@Model.Lease.Property!.Name</a>
                    </dd>
                    <dt class="col-sm-3">Tenants</dt>
                    <dd class="col-sm-9">
                        @if (Model.Lease.Tenants.Any())
                        {
                            foreach (var t in Model.Lease.Tenants)
                            {
                                <a asp-page="/Tenants/Details" asp-route-id="@t.Id" class="badge bg-secondary me-1 text-decoration-none">@t.DisplayName</a>
                            }
                        }
                        else { <span class="text-muted">(none)</span> }
                    </dd>
                    <dt class="col-sm-3">Term</dt>
                    <dd class="col-sm-9">
                        @Model.Lease.StartDate.ToString("yyyy-MM-dd") &mdash;
                        @(Model.Lease.IsMonthToMonth ? "month-to-month" : Model.Lease.EndDate.ToString("yyyy-MM-dd"))
                    </dd>
                    <dt class="col-sm-3">Security deposit</dt>
                    <dd class="col-sm-9">@Model.Lease.SecurityDeposit.ToString("C")</dd>
                    <dt class="col-sm-3">Rent due day</dt>
                    <dd class="col-sm-9">@Model.Lease.RentDueDay of each month</dd>
                    <dt class="col-sm-3">Late fee</dt>
                    <dd class="col-sm-9">
                        @if (Model.Lease.LateFeeAmount > 0)
                        {
                            @Model.Lease.LateFeeAmount.ToString("C")
                            @:after @Model.Lease.LateFeeGraceDays day(s)
                        }
                        else { <span class="text-muted">None</span> }
                    </dd>
                    @if (!string.IsNullOrWhiteSpace(Model.Lease.Notes))
                    {
                        <dt class="col-sm-3">Notes</dt>
                        <dd class="col-sm-9">@Model.Lease.Notes</dd>
                    }
                </dl>
            </div>

            <div class="tab-pane fade" id="tab-unpaid" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Unpaid Bills</h5>
                    @if (Model.UnpaidCount > 0)
                    {
                        <span class="badge bg-danger">@Model.UnpaidCount unpaid • @Model.CurrentBalance.ToString("C")</span>
                    }
                    else
                    {
                        <span class="badge bg-success">All paid</span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table mb-0 js-datatable" data-order='[[1,"asc"]]' data-page-length="25">
                        <thead class="table-light">
                            <tr><th>Period</th><th>Due</th><th class="text-end">Due</th><th class="text-end">Paid</th><th class="text-end">Balance</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                        @foreach (var c in Model.Charges.Where(x => x.Balance > 0).OrderBy(x => x.DueDate))
                        {
                            <tr>
                                <td>@c.PeriodLabel</td>
                                <td>@c.DueDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@c.AmountDue.ToString("C")</td>
                                <td class="text-end">@c.AmountPaid.ToString("C")</td>
                                <td class="text-end fw-bold">@c.Balance.ToString("C")</td>
                                <td>
                                    @switch (c.Status)
                                    {
                                        case PropertyPayPro.Models.ChargeStatus.PartiallyPaid:
                                            <span class="badge bg-warning text-dark">Partial</span>
                                            break;
                                        case PropertyPayPro.Models.ChargeStatus.Overdue:
                                            <span class="badge bg-danger">Overdue</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">Unpaid</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-bills" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Bill History</h5>
                    <a asp-page="/Bills/Index" class="btn btn-sm btn-outline-primary">All bills</a>
                </div>
                <div class="table-responsive">
                    <table class="table mb-0 js-datatable" data-order='[[1,"desc"]]' data-page-length="25">
                        <thead class="table-light">
                            <tr><th>Period</th><th>Due</th><th class="text-end">Due</th><th class="text-end">Paid</th><th class="text-end">Balance</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                        @foreach (var c in Model.Charges)
                        {
                            <tr>
                                <td>@c.PeriodLabel</td>
                                <td>@c.DueDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@c.AmountDue.ToString("C")</td>
                                <td class="text-end">@c.AmountPaid.ToString("C")</td>
                                <td class="text-end @(c.Balance > 0 ? "fw-bold" : "")">@c.Balance.ToString("C")</td>
                                <td>
                                    @switch (c.Status)
                                    {
                                        case PropertyPayPro.Models.ChargeStatus.Paid:
                                            <span class="badge bg-success">Paid</span>
                                            break;
                                        case PropertyPayPro.Models.ChargeStatus.PartiallyPaid:
                                            <span class="badge bg-warning text-dark">Partial</span>
                                            break;
                                        case PropertyPayPro.Models.ChargeStatus.Overdue:
                                            <span class="badge bg-danger">Overdue</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">Unpaid</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-payments" role="tabpanel">
                <h5 class="mb-2">Payment History</h5>
                <div class="table-responsive">
                    <table class="table mb-0 js-datatable" data-order='[[0,"desc"]]' data-page-length="25">
                        <thead class="table-light">
                            <tr><th>Date</th><th>Method</th><th>Reference</th><th class="text-end">Amount</th><th></th></tr>
                        </thead>
                        <tbody>
                        @foreach (var p in Model.Lease.Payments.OrderByDescending(x => x.PaidOn))
                        {
                            <tr>
                                <td>@p.PaidOn.ToString("yyyy-MM-dd")</td>
                                <td><span class="badge badge-outline-primary">@p.Method</span></td>
                                <td>@p.Reference</td>
                                <td class="text-end fw-bold">@p.Amount.ToString("C")</td>
                                <td class="text-end">
                                    <a asp-page="/Receipts/Show" asp-route-id="@p.Id" class="btn btn-sm btn-outline-success">Receipt</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-docs" role="tabpanel">
                <h5 class="mb-2">Lease Documents</h5>
                <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" class="mb-3 row g-2 align-items-end">
                    <input type="hidden" name="leaseId" value="@Model.Lease.Id" />
                    <div class="col-md-4"><input type="file" name="file" class="form-control" required /></div>
                    <div class="col-md-6"><input type="text" name="description" class="form-control" placeholder="Description (optional)" maxlength="255" /></div>
                    <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Upload</button></div>
                </form>
                @if (Model.Lease.Documents.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0 js-datatable" data-order='[[1,"desc"]]' data-page-length="10">
                            <thead class="table-light"><tr><th>File</th><th>Uploaded</th><th></th></tr></thead>
                            <tbody>
                            @foreach (var d in Model.Lease.Documents.OrderByDescending(x => x.UploadedOn))
                            {
                                <tr>
                                    <td>
                                        @d.FileName
                                        @if (!string.IsNullOrWhiteSpace(d.Description))
                                        { <br /><small class="text-muted">@d.Description</small> }
                                    </td>
                                    <td>@d.UploadedOn.ToString("yyyy-MM-dd")</td>
                                    <td class="text-end">
                                        <a asp-page-handler="Download" asp-route-documentId="@d.Id" class="btn btn-sm btn-outline-secondary">Download</a>
                                        <form method="post" asp-page-handler="DeleteDocument" class="d-inline">
                                            <input type="hidden" name="documentId" value="@d.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete this document?')">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No documents uploaded.</p>
                }
            </div>

            <div class="tab-pane fade" id="tab-pdfs" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Generated PDFs</h5>
                    <a asp-page="/Documents/Index" asp-route-LeaseFilter="@Model.Lease.Id" class="btn btn-sm btn-outline-primary">All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0 js-datatable" data-order='[[0,"desc"]]' data-page-length="10">
                        <thead class="table-light"><tr><th>Date</th><th>Kind</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var d in Model.GeneratedDocs)
                        {
                            <tr>
                                <td>@d.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@d.Kind</td>
                                <td class="text-end">
                                    <a asp-page="/Documents/Index" asp-page-handler="Download" asp-route-id="@d.Id"
                                       class="btn btn-sm btn-outline-primary">PDF</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
