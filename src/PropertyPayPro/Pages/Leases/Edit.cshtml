@page "{id:int}"
@model PropertyPayPro.Pages.Leases.EditModel
@{
    ViewData["Title"] = "Edit Lease";
}

<h1>Edit Lease</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Lease.Id" />
            <div class="mb-3">
                <label asp-for="Lease.PropertyId" class="form-label">Property</label>
                <select asp-for="Lease.PropertyId" class="form-select" asp-items="Model.Properties"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Lease.TenantId" class="form-label">Tenant</label>
                <select asp-for="Lease.TenantId" class="form-select" asp-items="Model.Tenants"></select>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Lease.StartDate" class="form-label"></label>
                    <input asp-for="Lease.StartDate" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Lease.EndDate" class="form-label"></label>
                    <input asp-for="Lease.EndDate" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Lease.MonthlyRent" class="form-label"></label>
                    <input asp-for="Lease.MonthlyRent" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Lease.SecurityDeposit" class="form-label"></label>
                    <input asp-for="Lease.SecurityDeposit" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Lease.RentDueDay" class="form-label"></label>
                    <input asp-for="Lease.RentDueDay" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Lease.LateFeeAmount" class="form-label">Late fee</label>
                    <input asp-for="Lease.LateFeeAmount" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Lease.LateFeeGraceDays" class="form-label">Grace days</label>
                    <input asp-for="Lease.LateFeeGraceDays" class="form-control" />
                </div>
                <div class="col mb-3 align-self-end">
                    <div class="form-check">
                        <input asp-for="Lease.IsMonthToMonth" class="form-check-input" />
                        <label asp-for="Lease.IsMonthToMonth" class="form-check-label">Month-to-month</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Lease.Notes" class="form-label"></label>
                <textarea asp-for="Lease.Notes" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
