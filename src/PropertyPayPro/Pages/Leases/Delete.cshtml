@page "{id:int}"
@model PropertyPayPro.Pages.Leases.DeleteModel
@{
    ViewData["Title"] = "Delete Lease";
}

<h1 class="text-danger">Delete Lease</h1>
<p>Are you sure you want to delete the lease for <strong>@Model.Lease!.TenantNames</strong> at <strong>@Model.Lease.Property!.Name</strong>?</p>

<form method="post">
    <input type="hidden" asp-for="Lease.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
