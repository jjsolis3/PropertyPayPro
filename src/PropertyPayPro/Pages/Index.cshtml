@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="form-head mb-4">
    <h2 class="text-black font-w600 mb-0">Dashboard</h2>
    <p class="text-muted mb-0">Welcome back. Here's what's happening with your properties.</p>
</div>

        <div class="row">
            <div class="col-xl-3 col-sm-6">
                <div class="card overflow-hidden">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Properties</p>
                                <h3 class="text-black mb-0">@Model.PropertyCount</h3>
                            </div>
                            <span class="bgl-primary text-primary rounded-circle p-3"><i class="flaticon-381-home-2"></i></span>
                        </div>
                        <a asp-page="/Properties/Index" class="text-primary fs-14 mt-3 d-inline-block">Manage <i class="las la-arrow-right"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-sm-6">
                <div class="card overflow-hidden">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Active Leases</p>
                                <h3 class="text-black mb-0">@Model.ActiveLeaseCount</h3>
                            </div>
                            <span class="bgl-success text-success rounded-circle p-3"><i class="flaticon-381-notepad"></i></span>
                        </div>
                        <a asp-page="/Leases/Index" class="text-primary fs-14 mt-3 d-inline-block">Manage <i class="las la-arrow-right"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-sm-6">
                <div class="card overflow-hidden">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Outstanding Balance</p>
                                <h3 class="text-black mb-0">@Model.OutstandingBalance.ToString("C")</h3>
                            </div>
                            <span class="bgl-warning text-warning rounded-circle p-3"><i class="flaticon-381-list"></i></span>
                        </div>
                        <a asp-page="/Bills/Index" class="text-primary fs-14 mt-3 d-inline-block">View Bills <i class="las la-arrow-right"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-sm-6">
                <div class="card overflow-hidden">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted mb-1">Collected This Month</p>
                                <h3 class="text-black mb-0">@Model.CollectedThisMonth.ToString("C")</h3>
                            </div>
                            <span class="bgl-info text-info rounded-circle p-3"><i class="las la-dollar-sign"></i></span>
                        </div>
                        <a asp-page="/Payments/Index" class="text-primary fs-14 mt-3 d-inline-block">View Payments <i class="las la-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.OverdueCount > 0)
        {
            <div class="alert alert-warning">
                <strong>@Model.OverdueCount overdue bill(s).</strong>
                <a asp-page="/Bills/Index" asp-route-StatusFilter="Overdue" class="alert-link">Review overdue</a>
            </div>
        }

        @if (Model.UpcomingMaintenance.Any())
        {
            <div class="card border-info mb-3">
                <div class="card-header d-flex justify-content-between align-items-center bg-info-subtle">
                    <h5 class="mb-0">
                        <i class="las la-tools text-info"></i>
                        Upcoming maintenance
                        <small class="text-muted ms-2">Next 30 days</small>
                    </h5>
                    <a asp-page="/Maintenance/Index" class="btn btn-sm btn-outline-info">Manage schedules</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr><th>Title</th><th>Property</th><th>Next Due</th><th>Cadence</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var m in Model.UpcomingMaintenance)
                            {
                                var days = m.DaysUntilDue;
                                var badgeColor = days < 0 ? "danger" : (days <= m.LeadDays ? "warning" : "success");
                                var badgeText = days < 0
                                    ? $"Overdue {-days}d"
                                    : (days == 0 ? "Due today" : $"In {days}d");
                                <tr>
                                    <td class="fw-semibold">@m.Title</td>
                                    <td>@m.Property?.Name</td>
                                    <td>
                                        @m.NextDueDate.ToString("yyyy-MM-dd")
                                        <span class="badge bg-@badgeColor ms-2">@badgeText</span>
                                    </td>
                                    <td>Every @m.RecurrenceMonths mo</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (Model.ExpiringSoonDocs.Any() || Model.ExpiredDocCount > 0)
        {
            <div class="card border-warning mb-3">
                <div class="card-header d-flex justify-content-between align-items-center bg-warning-subtle">
                    <h5 class="mb-0">
                        <i class="las la-exclamation-triangle text-warning"></i>
                        Documents expiring soon
                        <small class="text-muted ms-2">
                            @Model.ExpiringSoonCount in next 30d
                            @if (Model.ExpiredDocCount > 0)
                            {
                                <span class="text-danger">• @Model.ExpiredDocCount already expired</span>
                            }
                        </small>
                    </h5>
                    <a asp-page="/Documents/LeaseHub" asp-route-Status="expiring" class="btn btn-sm btn-outline-warning">Review</a>
                </div>
                @if (Model.ExpiringSoonDocs.Any())
                {
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>File</th><th>Type</th><th>Property</th><th>Expires</th><th></th></tr>
                                </thead>
                                <tbody>
                                @foreach (var d in Model.ExpiringSoonDocs)
                                {
                                    var status = PropertyPayPro.Pages.Shared.LeaseDocumentDisplay.StatusBadge(d.ExpiresOn);
                                    var typeColor = PropertyPayPro.Pages.Shared.LeaseDocumentDisplay.TypeBadgeColor(d.Type);
                                    var typeLabel = PropertyPayPro.Pages.Shared.LeaseDocumentDisplay.TypeLabel(d.Type);
                                    <tr>
                                        <td class="fw-semibold">@d.FileName</td>
                                        <td><span class="badge bg-@typeColor">@typeLabel</span></td>
                                        <td>@d.Lease?.Property?.Name</td>
                                        <td><span class="badge bg-@status.color">@status.label</span></td>
                                        <td class="text-end">
                                            <a asp-page="/Documents/Preview" asp-route-id="@d.Id" class="btn btn-sm btn-outline-info">Preview</a>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="row">
            <div class="col-xl-7">
                <div class="card">
                    <div class="card-header border-0 pb-0">
                        <h4 class="card-title">Recent Payments</h4>
                        <a asp-page="/Payments/Index" class="btn btn-sm btn-outline-primary">View all</a>
                    </div>
                    <div class="card-body">
                        @if (Model.RecentPayments.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-responsive-md mb-0">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Tenant</th>
                                            <th>Property</th>
                                            <th>Method</th>
                                            <th class="text-end">Amount</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in Model.RecentPayments)
                                        {
                                            <tr>
                                                <td>@p.PaidOn.ToString("yyyy-MM-dd")</td>
                                                <td>@p.Lease!.TenantNames</td>
                                                <td>@p.Lease.Property!.Name</td>
                                                <td><span class="badge badge-rounded badge-outline-primary">@p.Method</span></td>
                                                <td class="text-end fw-bold">@p.Amount.ToString("C")</td>
                                                <td class="text-end">
                                                    <a asp-page="/Receipts/Show" asp-route-id="@p.Id" class="btn btn-sm btn-outline-success">Receipt</a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No payments recorded yet. <a asp-page="/Payments/Create">Record one</a>.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-xl-5">
                <div class="card">
                    <div class="card-header border-0 pb-0">
                        <h4 class="card-title">Upcoming Bills</h4>
                        <a asp-page="/Bills/Index" class="btn btn-sm btn-outline-primary">View all</a>
                    </div>
                    <div class="card-body">
                        @if (Model.UpcomingBills.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-responsive-md mb-0">
                                    <thead>
                                        <tr>
                                            <th>Period</th>
                                            <th>Tenant</th>
                                            <th>Due</th>
                                            <th class="text-end">Balance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var c in Model.UpcomingBills)
                                        {
                                            <tr>
                                                <td>@c.PeriodLabel</td>
                                                <td>@c.Lease!.TenantNames</td>
                                                <td>@c.DueDate.ToString("MM-dd")</td>
                                                <td class="text-end fw-bold">@c.Balance.ToString("C")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No outstanding bills. <a asp-page="/Bills/Generate">Generate this month's</a>.</p>
                        }
            </div>
        </div>
    </div>
</div>
