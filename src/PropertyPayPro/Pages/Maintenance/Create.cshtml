@page
@model PropertyPayPro.Pages.Maintenance.CreateModel
@{
    ViewData["Title"] = "New Maintenance Schedule";
    var s = Model.Schedule;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">New Maintenance Schedule</h1>
    <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Schedule.Title" class="form-label"></label>
                    <input asp-for="Schedule.Title" class="form-control"
                           placeholder="e.g. Semi-annual HVAC service" />
                    <span asp-validation-for="Schedule.Title" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Schedule.PropertyId" class="form-label">Property</label>
                    <select asp-for="Schedule.PropertyId" asp-items="Model.Properties" class="form-select">
                        <option value="">— Pick a property —</option>
                    </select>
                    <span asp-validation-for="Schedule.PropertyId" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Schedule.Category" class="form-label"></label>
                    <select asp-for="Schedule.Category"
                            asp-items="Html.GetEnumSelectList<PropertyPayPro.Models.ServiceCategory>()"
                            class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Schedule.Vendor" class="form-label">Preferred vendor</label>
                    <input asp-for="Schedule.Vendor" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Schedule.VendorPhone" class="form-label">Vendor phone</label>
                    <input asp-for="Schedule.VendorPhone" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label asp-for="Schedule.RecurrenceMonths" class="form-label">Repeat every (months)</label>
                    <input asp-for="Schedule.RecurrenceMonths" type="number" min="1" max="60" class="form-control" />
                    <small class="text-muted">1 = monthly, 6 = twice a year, 12 = annually.</small>
                </div>
                <div class="col-md-3">
                    <label asp-for="Schedule.NextDueDate" class="form-label">Next due date</label>
                    <input asp-for="Schedule.NextDueDate" type="date" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Schedule.LeadDays" class="form-label">Lead-time (days)</label>
                    <input asp-for="Schedule.LeadDays" type="number" min="0" max="180" class="form-control" />
                    <small class="text-muted">Ticket generated this many days before Next Due.</small>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="Schedule.Active" class="form-check-input" />
                        <label asp-for="Schedule.Active" class="form-check-label">Active</label>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="Schedule.Description" class="form-label"></label>
                    <textarea asp-for="Schedule.Description" class="form-control" rows="3"
                              placeholder="What service is performed, access notes, expected duration, etc."></textarea>
                </div>

                <div class="col-md-6">
                    <div class="form-check mb-2">
                        <input asp-for="Schedule.NotifyTenants" class="form-check-input" />
                        <label asp-for="Schedule.NotifyTenants" class="form-check-label">
                            Email tenants at this property when a ticket is generated
                        </label>
                    </div>
                    <div class="form-check">
                        <input asp-for="Schedule.NotifyAdmins" class="form-check-input" />
                        <label asp-for="Schedule.NotifyAdmins" class="form-check-label">
                            Email admins &amp; managers when a ticket is generated
                        </label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Schedule.Notes" class="form-label">Internal notes (optional)</label>
                    <input asp-for="Schedule.Notes" class="form-control" />
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Create schedule</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
