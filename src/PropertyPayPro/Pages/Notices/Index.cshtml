@page
@model PropertyPayPro.Pages.Notices.IndexModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "Notices";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Notices</h1>
        <div class="text-muted">Every formal notice generated across all leases.</div>
    </div>
    <div>
        <a asp-page="Broadcast" class="btn btn-outline-info">
            <i class="las la-bullhorn"></i> Broadcast
        </a>
        @if (User.IsInRole(IdentitySeed.AdminRole))
        {
            <a asp-page="Create" class="btn btn-success">
                <i class="las la-plus"></i> New Notice
            </a>
        }
    </div>
</div>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Notices on File", Value = Model.TotalCount.ToString(),
        Color = "primary", Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "In the Last 30 Days", Value = Model.Last30DaysCount.ToString(),
        Color = "info", Icon = "flaticon-381-time" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Properties", Value = Model.Properties.Count.ToString(),
        Color = "success", Icon = "flaticon-381-home-2" })" />
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-6">
                <input asp-for="Q" class="form-control" placeholder="Search notice title, filename, property..." />
            </div>
            <div class="col-md-4">
                <select asp-for="PropertyFilter" class="form-select">
                    <option value="">All properties</option>
                    @foreach (var p in Model.Properties)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-striped mb-0 js-datatable" data-order='[[3,"desc"]]'>
                <thead>
                    <tr>
                        <th>Notice</th>
                        <th>Property / Lease</th>
                        <th>Effective</th>
                        <th>Generated</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var d in Model.Notices)
                {
                    <tr>
                        <td>
                            <span class="fw-semibold">@(d.Description ?? d.FileName)</span>
                            <br /><small class="text-muted">@d.FileName</small>
                        </td>
                        <td>
                            <div>@d.Lease?.Property?.Name</div>
                            <small class="text-muted">@d.Lease?.TenantNames</small>
                        </td>
                        <td>@(d.EffectiveDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td>@d.UploadedOn.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a asp-page="/Documents/Preview" asp-route-id="@d.Id" class="btn btn-sm btn-outline-info">Preview</a>
                            <a asp-page="/Leases/Details" asp-route-id="@d.LeaseId" class="btn btn-sm btn-outline-secondary">Lease</a>
                        </td>
                    </tr>
                }
                @if (!Model.Notices.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">
                        No notices yet.
                        @if (User.IsInRole(IdentitySeed.AdminRole))
                        {
                            <a asp-page="Create">Create one</a>
                            @:.
                        }
                    </td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
