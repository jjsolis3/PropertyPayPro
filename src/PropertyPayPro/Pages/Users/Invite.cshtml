@page
@model PropertyPayPro.Pages.Users.InviteModel
@{
    ViewData["Title"] = "Invite User";
}

<h1 class="h3 mb-3">Invite User</h1>

<div class="row">
    <div class="col-md-8">
        @if (!string.IsNullOrEmpty(Model.InviteLink))
        {
            <div class="alert @(Model.EmailSent ? "alert-success" : Model.EmailError is not null ? "alert-warning" : "alert-info")">
                <h5 class="alert-heading">Invitation created for @Model.InviteEmail</h5>

                @if (Model.EmailSent)
                {
                    <p class="mb-2">
                        <strong>✓ Invite emailed</strong> to @Model.InviteEmail. They should receive it within a few minutes.
                    </p>
                }
                else if (Model.EmailError is not null)
                {
                    <p class="mb-2">
                        <strong>⚠ Email send failed:</strong> @Model.EmailError
                        <br/>Share the link below manually instead:
                    </p>
                }
                else if (!Model.MailConfigured)
                {
                    <p class="mb-2">
                        SMTP isn't configured. Copy the link below and share it with the user manually.
                        (Configure SMTP under Settings → Email to have future invites emailed automatically.)
                    </p>
                }
                else
                {
                    <p class="mb-2">Share this one-time link so they can set their password and log in:</p>
                }

                <div class="input-group">
                    <input type="text" readonly value="@Model.InviteLink" class="form-control" onclick="this.select()" />
                    <button type="button" class="btn btn-outline-primary"
                            onclick="navigator.clipboard.writeText('@Model.InviteLink'); PPS.toast.success('Invite link copied.');">
                        Copy
                    </button>
                </div>
                <small class="text-muted d-block mt-2">
                    Link expires within 24 hours per Identity defaults.
                </small>
                <div class="mt-3">
                    <a asp-page="Index" class="btn btn-outline-secondary">Back to Users</a>
                    <a asp-page="Invite" class="btn btn-success">Invite Another</a>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="row">
                            <div class="col mb-3">
                                <label asp-for="Input.FirstName" class="form-label"></label>
                                <input asp-for="Input.FirstName" class="form-control" />
                                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                            </div>
                            <div class="col mb-3">
                                <label asp-for="Input.LastName" class="form-label"></label>
                                <input asp-for="Input.LastName" class="form-control" />
                                <span asp-validation-for="Input.LastName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" type="email" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Role" class="form-label"></label>
                            <div class="btn-group d-flex" role="group" aria-label="Role">
                                <input type="radio" class="btn-check" name="Input.Role" id="role-standard"
                                       value="@PropertyPayPro.Pages.Users.InviteModel.InviteRole.Standard"
                                       @(Model.Input.Role == PropertyPayPro.Pages.Users.InviteModel.InviteRole.Standard ? "checked" : "") />
                                <label class="btn btn-outline-secondary" for="role-standard">Standard</label>

                                <input type="radio" class="btn-check" name="Input.Role" id="role-manager"
                                       value="@PropertyPayPro.Pages.Users.InviteModel.InviteRole.Manager"
                                       @(Model.Input.Role == PropertyPayPro.Pages.Users.InviteModel.InviteRole.Manager ? "checked" : "") />
                                <label class="btn btn-outline-info" for="role-manager">Manager (read-only)</label>

                                <input type="radio" class="btn-check" name="Input.Role" id="role-admin"
                                       value="@PropertyPayPro.Pages.Users.InviteModel.InviteRole.Admin"
                                       @(Model.Input.Role == PropertyPayPro.Pages.Users.InviteModel.InviteRole.Admin ? "checked" : "") />
                                <label class="btn btn-outline-primary" for="role-admin">Admin</label>

                                <input type="radio" class="btn-check" name="Input.Role" id="role-tenant"
                                       value="@PropertyPayPro.Pages.Users.InviteModel.InviteRole.Tenant"
                                       @(Model.Input.Role == PropertyPayPro.Pages.Users.InviteModel.InviteRole.Tenant ? "checked" : "") />
                                <label class="btn btn-outline-success" for="role-tenant">Tenant (portal)</label>
                            </div>
                            <small class="text-muted d-block mt-1">
                                <strong>Manager:</strong> read-only across Properties/Tenants/Leases/Bills/Payments/Expenses/Services/Reports.
                                No Create/Edit/Delete; no Settings or Users.<br />
                                <strong>Admin:</strong> full access.<br />
                                <strong>Tenant:</strong> portal login — sees only their own bills, payments, expenses, tickets, and lease documents.
                            </small>
                        </div>

                        <div class="mb-3" id="tenant-picker"
                             style="@(Model.Input.Role == PropertyPayPro.Pages.Users.InviteModel.InviteRole.Tenant ? "" : "display: none;")">
                            <label asp-for="Input.TenantId" class="form-label"></label>
                            <select asp-for="Input.TenantId" asp-items="Model.TenantOptions" class="form-select">
                                <option value="">— Pick a tenant record —</option>
                            </select>
                            <span asp-validation-for="Input.TenantId" class="text-danger"></span>
                            <small class="text-muted">
                                Only tenants that don't already have a portal login are listed.
                                Create the Tenant record first under Tenants → New Tenant if it's missing.
                            </small>
                        </div>

                        <button type="submit" class="btn btn-primary">Create Invitation</button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var picker = document.getElementById('tenant-picker');
            document.querySelectorAll('input[name="Input.Role"]').forEach(function (radio) {
                radio.addEventListener('change', function () {
                    picker.style.display = (radio.value === 'Tenant' && radio.checked) ? '' : 'none';
                });
            });
        })();
    </script>
}
