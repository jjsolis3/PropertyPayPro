@page
@model PropertyPayPro.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Generated Documents";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Generated Documents</h1>
        <p class="text-muted mb-0">Archive of all PDFs generated by the system.</p>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Kind</label>
                <select asp-for="KindFilter" class="form-select"
                        asp-items="Html.GetEnumSelectList<PropertyPayPro.Models.GeneratedDocumentKind>()">
                    <option value="">All kinds</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label">Lease</label>
                <select asp-for="LeaseFilter" class="form-select">
                    <option value="">All leases</option>
                    @foreach (var l in Model.LeaseOptions)
                    {
                        <option value="@l.Id" selected="@(Model.LeaseFilter == l.Id)">
                            @l.TenantNames — @l.Property!.Name
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Generated</th>
                        <th>Kind</th>
                        <th>Lease</th>
                        <th>Reference</th>
                        <th>File</th>
                        <th class="text-end">Size</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var d in Model.Documents)
                {
                    <tr>
                        <td>@d.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @switch (d.Kind)
                            {
                                case PropertyPayPro.Models.GeneratedDocumentKind.Bill:
                                    <span class="badge bg-primary">Bill</span>
                                    break;
                                case PropertyPayPro.Models.GeneratedDocumentKind.Receipt:
                                    <span class="badge bg-success">Receipt</span>
                                    break;
                                case PropertyPayPro.Models.GeneratedDocumentKind.UnpaidStatement:
                                    <span class="badge bg-warning text-dark">Statement</span>
                                    break;
                                case PropertyPayPro.Models.GeneratedDocumentKind.BillPaidConfirmation:
                                    <span class="badge bg-info">Bill Paid</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (d.Lease is not null)
                            {
                                @d.Lease.TenantNames <br />
                                <small class="text-muted">@d.Lease.Property?.Name</small>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            @if (d.RentalChargeId.HasValue) { <span>Invoice #@d.RentalChargeId.Value.ToString("D8")</span> }
                            else if (d.RentPaymentId.HasValue) { <span>Payment #@d.RentPaymentId.Value.ToString("D8")</span> }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>@d.FileName</td>
                        <td class="text-end">@($"{d.SizeBytes / 1024.0:N1} KB")</td>
                        <td class="text-end">
                            <a asp-page-handler="Download" asp-route-id="@d.Id"
                               class="btn btn-sm btn-outline-primary">Download</a>
                        </td>
                    </tr>
                }
                @if (!Model.Documents.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No documents yet.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
