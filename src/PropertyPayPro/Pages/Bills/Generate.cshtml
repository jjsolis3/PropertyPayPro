@page
@model PropertyPayPro.Pages.Bills.GenerateModel
@{
    ViewData["Title"] = "Generate Bills";
}

<h1>Generate Monthly Bills</h1>

<p class="text-muted">
    Creates a rent charge for every active lease for the selected month.
    Bills due on the 15th. Running this twice for the same month is safe — duplicates are skipped.
</p>

@if (Model.Message is not null)
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="post" class="row g-2 align-items-end">
    <div class="col-auto">
        <label asp-for="Year" class="form-label">Year</label>
        <input asp-for="Year" class="form-control" type="number" min="2020" max="2100" />
    </div>
    <div class="col-auto">
        <label asp-for="Month" class="form-label">Month</label>
        <input asp-for="Month" class="form-control" type="number" min="1" max="12" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Generate</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</form>
