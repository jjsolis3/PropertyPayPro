@page "{id:int}"
@model PropertyPayPro.Pages.Bills.DetailsModel
@{
    ViewData["Title"] = "Bill Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.Charge!.PeriodLabel — @Model.Charge.Lease!.TenantNames</h1>
    <form method="post" asp-page-handler="GeneratePdf" asp-route-id="@Model.Charge.Id" class="d-inline">
        <button type="submit" class="btn btn-outline-primary">Generate Bill PDF</button>
    </form>
</div>

@if (TempData["PdfStatus"] is string ps)
{
    <div class="alert alert-info alert-dismissible fade show">@ps
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<dl class="row">
    <dt class="col-sm-3">Property</dt><dd class="col-sm-9">@Model.Charge.Lease.Property!.Name</dd>
    <dt class="col-sm-3">Billing period</dt><dd class="col-sm-9">@Model.Charge.PeriodLabel</dd>
    <dt class="col-sm-3">Due date</dt><dd class="col-sm-9">@Model.Charge.DueDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Amount due</dt><dd class="col-sm-9">@Model.Charge.AmountDue.ToString("C")</dd>
    <dt class="col-sm-3">Amount paid</dt><dd class="col-sm-9">@Model.Charge.AmountPaid.ToString("C")</dd>
    <dt class="col-sm-3">Balance</dt><dd class="col-sm-9"><strong>@Model.Charge.Balance.ToString("C")</strong></dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Charge.Status</dd>
    <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@Model.Charge.Notes</dd>
</dl>

<h3>Payments applied</h3>
@if (Model.Charge.Allocations.Any())
{
    <table class="table table-sm js-datatable" data-order='[[0,"desc"]]' data-page-length="10">
        <thead><tr><th>Date</th><th>Paid by</th><th>Method</th><th>Reference</th><th class="text-end">Amount applied</th><th></th></tr></thead>
        <tbody>
        @foreach (var a in Model.Charge.Allocations.OrderByDescending(x => x.Payment!.PaidOn))
        {
            <tr>
                <td>@a.Payment!.PaidOn.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (a.Payment.PaidByTenant is not null)
                    { <span class="fw-semibold">@a.Payment.PaidByTenant.DisplayName</span> }
                    else
                    { <span class="text-muted">(unspecified)</span> }
                </td>
                <td><span class="badge badge-outline-primary">@a.Payment.Method</span></td>
                <td>@a.Payment.Reference</td>
                <td class="text-end fw-bold">@a.Amount.ToString("C")</td>
                <td class="text-end">
                    <a asp-page="/Receipts/Show" asp-route-id="@a.RentPaymentId" class="btn btn-sm btn-outline-secondary">Receipt</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No payments applied yet.</p>
}

@if (Model.Documents.Any())
{
    <h3>Generated PDFs</h3>
    <table class="table table-sm">
        <thead><tr><th>Kind</th><th>File</th><th>Generated</th><th class="text-end">Size</th><th></th></tr></thead>
        <tbody>
        @foreach (var d in Model.Documents)
        {
            <tr>
                <td>@d.Kind</td>
                <td>@d.FileName</td>
                <td>@d.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td class="text-end">@($"{d.SizeBytes / 1024.0:N1} KB")</td>
                <td class="text-end">
                    <a asp-page="/Documents/Index" asp-page-handler="Download" asp-route-id="@d.Id"
                       class="btn btn-sm btn-outline-primary">Download</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<a asp-page="/Payments/Create" asp-route-leaseId="@Model.Charge.LeaseId" class="btn btn-success">Record Payment</a>
<a asp-page="Edit" asp-route-id="@Model.Charge.Id" class="btn btn-primary">Edit</a>
<a asp-page="Index" class="btn btn-outline-secondary">Back</a>
