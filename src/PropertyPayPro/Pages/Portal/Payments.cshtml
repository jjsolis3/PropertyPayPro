@page
@model PropertyPayPro.Pages.Portal.PaymentsModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "My Payments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">My Payments</h1>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Paid This Year", Value = Model.PaidThisYear.ToString("C"),
        SubText = $"Since Jan 1, {DateTime.UtcNow.Year}",
        Color = "success", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Lifetime Paid", Value = Model.LifetimePaid.ToString("C"),
        Color = "primary", Icon = "flaticon-381-notepad" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Payment Count", Value = Model.PaymentCount.ToString(),
        Color = "info", Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Last Payment",
        Value = Model.Payments.FirstOrDefault()?.PaidOn.ToString("MMM d") ?? "—",
        SubText = Model.Payments.FirstOrDefault()?.Amount.ToString("C") ?? "",
        Color = "warning", Icon = "flaticon-381-time" })" />
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped mb-0 js-datatable" data-order='[[0,"desc"]]'>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Property</th>
                        <th>Method</th>
                        <th>Reference</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Payments)
                {
                    <tr>
                        <td>@p.PaidOn.ToString("yyyy-MM-dd")</td>
                        <td>@p.Lease?.Property?.Name</td>
                        <td><span class="badge badge-outline-primary">@p.Method</span></td>
                        <td class="text-muted small">@p.Reference</td>
                        <td class="text-end fw-bold">@p.Amount.ToString("C")</td>
                    </tr>
                }
                @if (!Model.Payments.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">No payments recorded yet.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
