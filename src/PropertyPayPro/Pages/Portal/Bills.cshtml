@page
@model PropertyPayPro.Pages.Portal.BillsModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "My Bills";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">My Bills</h1>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Total Owed", Value = Model.TotalBalance.ToString("C"),
        SubText = Model.TotalBalance > 0 ? "Balance across all bills" : "Nothing outstanding",
        Color = Model.TotalBalance > 0 ? "danger" : "success",
        Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Your Share (Lifetime)", Value = Model.TotalShare.ToString("C"),
        Color = "primary", Icon = "flaticon-381-notepad" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "You've Paid", Value = Model.TotalPaid.ToString("C"),
        Color = "success", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Bill Count", Value = Model.Rows.Count.ToString(),
        Color = "info", Icon = "flaticon-381-time" })" />
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped mb-0 js-datatable" data-order='[[1,"desc"]]'>
                <thead>
                    <tr>
                        <th>Period</th>
                        <th>Due</th>
                        <th>Property</th>
                        <th class="text-end">Your Share</th>
                        <th class="text-end">Paid</th>
                        <th class="text-end">Balance</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Rows)
                {
                    var c = r.Charge;
                    <tr>
                        <td>
                            @c.PeriodLabel
                            @if (c.Kind == PropertyPayPro.Models.ChargeKind.LateFee) { <span class="badge bg-warning text-dark ms-1">Late fee</span> }
                        </td>
                        <td>@c.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>@c.Lease!.Property?.Name</td>
                        <td class="text-end">@r.TenantShare.ToString("C")</td>
                        <td class="text-end">@r.PaidByTenant.ToString("C")</td>
                        <td class="text-end fw-bold">@r.Balance.ToString("C")</td>
                        <td>
                            @if (r.Balance <= 0m)
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else if (r.PaidByTenant > 0m)
                            {
                                <span class="badge bg-warning text-dark">Partial</span>
                            }
                            else if (c.DueDate < DateOnly.FromDateTime(DateTime.UtcNow))
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Unpaid</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Rows.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No bills on file.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
