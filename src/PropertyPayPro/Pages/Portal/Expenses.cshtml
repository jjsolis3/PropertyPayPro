@page
@model PropertyPayPro.Pages.Portal.ExpensesModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "Pass-through Expenses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Pass-through Expenses</h1>
        <div class="text-muted">Property expenses your landlord has passed through for reimbursement.</div>
    </div>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Owed", Value = Model.OutstandingTotal.ToString("C"),
        SubText = $"{Model.OutstandingCount} item(s)",
        Color = Model.OutstandingTotal > 0 ? "danger" : "success",
        Icon = "flaticon-381-warning" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Reimbursed", Value = Model.ReimbursedTotal.ToString("C"),
        Color = "success", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Items on File", Value = Model.Expenses.Count.ToString(),
        Color = "primary", Icon = "flaticon-381-briefcase" })" />
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped mb-0 js-datatable" data-order='[[1,"desc"]]'>
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Due</th>
                        <th>Property</th>
                        <th>Category</th>
                        <th>Vendor</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">Reimbursed</th>
                        <th class="text-end">Outstanding</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var e in Model.Expenses)
                {
                    <tr>
                        <td>@e.Description</td>
                        <td>@(e.DueDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td>@e.Property?.Name</td>
                        <td><span class="badge badge-outline-info">@e.Category</span></td>
                        <td class="text-muted">@e.Vendor</td>
                        <td class="text-end">@e.AmountDue.ToString("C")</td>
                        <td class="text-end">@((e.ReimbursedAmount ?? 0m).ToString("C"))</td>
                        <td class="text-end fw-bold">@e.OutstandingReimbursement.ToString("C")</td>
                        <td>
                            @if (e.IsReimbursed)
                            {
                                <span class="badge bg-success">Reimbursed @e.ReimbursedOn?.ToString("MMM d")</span>
                            }
                            else if (e.OutstandingReimbursement > 0)
                            {
                                <span class="badge bg-warning text-dark">Owed</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">—</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Expenses.Any())
                {
                    <tr><td colspan="9" class="text-center text-success py-3">No pass-through expenses assigned to you.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
