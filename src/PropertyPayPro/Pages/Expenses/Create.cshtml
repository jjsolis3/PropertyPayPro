@page
@model PropertyPayPro.Pages.Expenses.CreateModel
@{
    ViewData["Title"] = "New Expense";
}

<h1>New Property Expense</h1>

<div class="row">
    <div class="col-md-7">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Expense.PropertyId" class="form-label">Property</label>
                <select asp-for="Expense.PropertyId" class="form-select" asp-items="Model.Properties"></select>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Expense.Category" class="form-label"></label>
                    <select asp-for="Expense.Category" class="form-select"
                            asp-items="Html.GetEnumSelectList<PropertyPayPro.Models.ExpenseCategory>()"></select>
                </div>
                <div class="col mb-3">
                    <label asp-for="Expense.Vendor" class="form-label"></label>
                    <input asp-for="Expense.Vendor" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Expense.Description" class="form-label"></label>
                <input asp-for="Expense.Description" class="form-control" />
                <span asp-validation-for="Expense.Description" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Expense.AmountDue" class="form-label"></label>
                    <input asp-for="Expense.AmountDue" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Expense.DueDate" class="form-label"></label>
                    <input asp-for="Expense.DueDate" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Expense.PaidOn" class="form-label"></label>
                    <input asp-for="Expense.PaidOn" class="form-control" />
                </div>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Expense.PassThroughToTenant" class="form-check-input" />
                <label asp-for="Expense.PassThroughToTenant" class="form-check-label">Pass through to tenant on next invoice</label>
            </div>
            <div class="mb-3">
                <label asp-for="Expense.Notes" class="form-label"></label>
                <textarea asp-for="Expense.Notes" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
