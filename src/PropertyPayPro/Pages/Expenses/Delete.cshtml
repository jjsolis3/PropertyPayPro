@page "{id:int}"
@model PropertyPayPro.Pages.Expenses.DeleteModel
@{
    ViewData["Title"] = "Delete Expense";
}

<h1 class="text-danger">Delete Expense</h1>
<p>Delete <strong>@Model.Expense!.Description</strong> (@Model.Expense.AmountDue.ToString("C"))?</p>

<form method="post">
    <input type="hidden" asp-for="Expense.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
