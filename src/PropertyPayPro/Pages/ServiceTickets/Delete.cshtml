@page "{id:int}"
@model PropertyPayPro.Pages.ServiceTickets.DeleteModel
@{
    ViewData["Title"] = "Delete Ticket";
}

<h1 class="text-danger">Delete Service Ticket</h1>
<p>Delete <strong>@Model.Ticket!.Title</strong>?</p>

<form method="post">
    <input type="hidden" asp-for="Ticket.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
