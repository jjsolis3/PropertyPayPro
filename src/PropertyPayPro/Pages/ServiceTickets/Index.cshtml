@page
@model PropertyPayPro.Pages.ServiceTickets.IndexModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "Service Tickets";
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Service Tickets</h1>
    @if (User.IsInRole(IdentitySeed.AdminRole))
    {
        <a asp-page="Create" class="btn btn-success">New Ticket</a>
    }
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Open Tickets", Value = Model.OpenCount.ToString(),
        Color = "warning", Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Scheduled This Week", Value = Model.ScheduledThisWeek.ToString(),
        Color = "info", Icon = "flaticon-381-time" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Spent This Month", Value = Model.SpentThisMonth.ToString("C"),
        Color = "primary", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Avg Resolution", Value = $"{Model.AvgDaysToResolve} days",
        SubText = "Closed in last 90 days",
        Color = "success", Icon = "flaticon-381-notepad" })" />
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped mb-0 js-datatable" data-order='[[5,"desc"]]'>
                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Priority</th>
                        <th>Category</th>
                        <th>Title / Vendor</th>
                        <th>Status</th>
                        <th>Reported</th>
                        <th>Scheduled</th>
                        <th>Resolved</th>
                        <th class="text-end">Quote / Cost</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var t in Model.Tickets)
                {
                    <tr>
                        <td>@t.Property!.Name</td>
                        <td>
                            @switch (t.Priority)
                            {
                                case PropertyPayPro.Models.ServicePriority.Urgent:
                                    <span class="badge bg-danger">Urgent</span>
                                    break;
                                case PropertyPayPro.Models.ServicePriority.High:
                                    <span class="badge bg-warning text-dark">High</span>
                                    break;
                                case PropertyPayPro.Models.ServicePriority.Low:
                                    <span class="badge bg-secondary">Low</span>
                                    break;
                                default:
                                    <span class="badge bg-info">Normal</span>
                                    break;
                            }
                        </td>
                        <td>@t.Category</td>
                        <td>
                            <div class="fw-semibold">
                                @t.Title
                                @if (t.WarrantyExpiresOn.HasValue && t.WarrantyExpiresOn.Value >= today)
                                {
                                    <span class="badge bg-success ms-1"
                                          title="Under warranty until @t.WarrantyExpiresOn.Value.ToString("yyyy-MM-dd")">
                                        Warranty
                                    </span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(t.Vendor))
                            {
                                <small class="text-muted">
                                    @t.Vendor
                                    @if (!string.IsNullOrWhiteSpace(t.VendorPhone))
                                    {
                                        <span>· @t.VendorPhone</span>
                                    }
                                </small>
                            }
                        </td>
                        <td>
                            @switch (t.Status)
                            {
                                case PropertyPayPro.Models.ServiceTicketStatus.Completed:
                                    <span class="badge bg-success">Completed</span>
                                    break;
                                case PropertyPayPro.Models.ServiceTicketStatus.InProgress:
                                    <span class="badge bg-info">In progress</span>
                                    break;
                                case PropertyPayPro.Models.ServiceTicketStatus.Cancelled:
                                    <span class="badge bg-secondary">Cancelled</span>
                                    break;
                                default:
                                    <span class="badge bg-warning text-dark">Open</span>
                                    break;
                            }
                            @if (t.PassThroughToTenant) { <br /><span class="badge bg-info mt-1">Pass-through</span> }
                        </td>
                        <td class="text-nowrap">@t.ReportedOn.ToString("yyyy-MM-dd")</td>
                        <td class="text-nowrap">
                            @if (!t.ScheduledFor.HasValue) { <span class="text-muted">—</span> }
                            else
                            {
                                @t.ScheduledFor.Value.ToString("yyyy-MM-dd")
                                @if (t.Status != PropertyPayPro.Models.ServiceTicketStatus.Completed
                                     && t.Status != PropertyPayPro.Models.ServiceTicketStatus.Cancelled
                                     && t.ScheduledFor.Value < today)
                                {
                                    <br /><span class="badge bg-danger">Overdue</span>
                                }
                            }
                        </td>
                        <td class="text-nowrap">@(t.ResolvedOn?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td class="text-end text-nowrap">
                            @if (t.QuotedAmount.HasValue)
                            {
                                <small class="text-muted">Q: @t.QuotedAmount.Value.ToString("C")</small>
                                <br />
                            }
                            @if (t.Cost.HasValue)
                            {
                                <span class="fw-semibold">@t.Cost.Value.ToString("C")</span>
                            }
                            else if (!t.QuotedAmount.HasValue)
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-page="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-page="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-page="Delete" asp-route-id="@t.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Tickets.Any())
                {
                    <tr><td colspan="10" class="text-center text-muted py-3">No service tickets yet.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
