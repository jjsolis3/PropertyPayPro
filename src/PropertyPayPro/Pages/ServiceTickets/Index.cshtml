@page
@model PropertyPayPro.Pages.ServiceTickets.IndexModel
@{
    ViewData["Title"] = "Service Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Service Tickets</h1>
    <a asp-page="Create" class="btn btn-success">New Ticket</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Property</th>
            <th>Category</th>
            <th>Title</th>
            <th>Vendor</th>
            <th>Reported</th>
            <th>Resolved</th>
            <th class="text-end">Cost</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var t in Model.Tickets)
    {
        <tr>
            <td>@t.Property!.Name</td>
            <td>@t.Category</td>
            <td>@t.Title</td>
            <td>@t.Vendor</td>
            <td>@t.ReportedOn.ToString("yyyy-MM-dd")</td>
            <td>@(t.ResolvedOn?.ToString("yyyy-MM-dd") ?? "—")</td>
            <td class="text-end">@(t.Cost?.ToString("C") ?? "—")</td>
            <td>
                @switch (t.Status)
                {
                    case PropertyPayPro.Models.ServiceTicketStatus.Completed:
                        <span class="badge bg-success">Completed</span>
                        break;
                    case PropertyPayPro.Models.ServiceTicketStatus.InProgress:
                        <span class="badge bg-info">In progress</span>
                        break;
                    case PropertyPayPro.Models.ServiceTicketStatus.Cancelled:
                        <span class="badge bg-secondary">Cancelled</span>
                        break;
                    default:
                        <span class="badge bg-warning text-dark">Open</span>
                        break;
                }
                @if (t.PassThroughToTenant) { <span class="badge bg-info ms-1">Pass-through</span> }
            </td>
            <td class="text-end">
                <a asp-page="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                <a asp-page="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-page="Delete" asp-route-id="@t.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
