@page
@model PropertyPayPro.Pages.Payments.CreateModel
@{
    ViewData["Title"] = "Record Payment";
}

<h1 class="h3 mb-3">Record Payment</h1>

<div class="row">
    <div class="col-md-10">
        <form method="post" id="paymentForm">
            <div class="card mb-3">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Payment.LeaseId" class="form-label">Lease</label>
                            <select asp-for="Payment.LeaseId" class="form-select" asp-items="Model.Leases" id="leaseSelect"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Payment.PaidOn" class="form-label"></label>
                            <input asp-for="Payment.PaidOn" class="form-control" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Payment.Amount" class="form-label"></label>
                            <input asp-for="Payment.Amount" class="form-control" id="amountInput" step="0.01" min="0" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Payment.Method" class="form-label"></label>
                            <select asp-for="Payment.Method" class="form-select"
                                    asp-items="Html.GetEnumSelectList<PropertyPayPro.Models.PaymentMethod>()"></select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Payment.Reference" class="form-label"></label>
                        <input asp-for="Payment.Reference" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Payment.Notes" class="form-label"></label>
                        <textarea asp-for="Payment.Notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h4 class="card-title mb-0">Allocate to bills</h4>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-outline-primary" id="selectAllBtn">Select all</button>
                        <button type="button" class="btn btn-outline-secondary" id="clearAllBtn">Clear all</button>
                        <button type="button" class="btn btn-outline-success" id="autoAllocateBtn">Auto-allocate oldest-first</button>
                    </div>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        Check a bill to apply the payment to it. Auto-allocate fills oldest-first up to the payment amount.
                        Any unallocated remainder is held as a credit on the lease.
                    </p>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 2.5rem;"></th>
                                    <th>Period</th>
                                    <th>Due</th>
                                    <th class="text-end">Balance</th>
                                    <th class="text-end" style="width: 10rem;">Apply</th>
                                </tr>
                            </thead>
                            <tbody id="allocationTbody">
                                <tr><td colspan="5" class="text-center text-muted py-3">Pick a lease to see outstanding bills.</td></tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="4" class="text-end">Total allocated</th>
                                    <th class="text-end" id="allocationTotal">$0.00</th>
                                </tr>
                                <tr>
                                    <th colspan="4" class="text-end text-muted">Remainder (held as credit)</th>
                                    <th class="text-end text-muted" id="allocationRemainder">$0.00</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" id="saveBtn">Save Payment</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const leaseSelect = document.getElementById('leaseSelect');
            const amountInput = document.getElementById('amountInput');
            const tbody = document.getElementById('allocationTbody');
            const totalEl = document.getElementById('allocationTotal');
            const remainderEl = document.getElementById('allocationRemainder');
            const autoBtn = document.getElementById('autoAllocateBtn');
            const selectAllBtn = document.getElementById('selectAllBtn');
            const clearAllBtn = document.getElementById('clearAllBtn');
            const form = document.getElementById('paymentForm');

            let charges = [];

            const fmt = n => '$' + (Number(n) || 0).toFixed(2);

            function renderTable() {
                if (!charges.length) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No outstanding bills for this lease. The full payment will be held as a credit.</td></tr>';
                    recalcTotal();
                    return;
                }
                tbody.innerHTML = charges.map((c, i) => `
                    <tr data-row="${i}">
                        <td>
                            <input type="checkbox" class="form-check-input alloc-check" data-row="${i}" />
                        </td>
                        <td>${c.label}</td>
                        <td>${c.dueDate}</td>
                        <td class="text-end">${fmt(c.balance)}</td>
                        <td>
                            <input type="hidden" name="AllocationChargeIds[${i}]" value="${c.id}" />
                            <input type="number" step="0.01" min="0" max="${c.balance}" value="0"
                                   name="AllocationAmounts[${i}]" data-row="${i}" disabled
                                   class="form-control form-control-sm alloc-amount text-end" />
                        </td>
                    </tr>
                `).join('');
                tbody.querySelectorAll('.alloc-check').forEach(el => el.addEventListener('change', onCheck));
                tbody.querySelectorAll('.alloc-amount').forEach(el => el.addEventListener('input', recalcTotal));
                recalcTotal();
            }

            function onCheck(e) {
                const i = Number(e.target.dataset.row);
                const amt = tbody.querySelector(`.alloc-amount[data-row="${i}"]`);
                if (e.target.checked) {
                    amt.disabled = false;
                    const remaining = remainingAvailable();
                    const apply = Math.min(charges[i].balance, Math.max(0, remaining + Number(amt.value || 0)));
                    amt.value = apply > 0 ? apply.toFixed(2) : charges[i].balance.toFixed(2);
                    amt.focus();
                    amt.select();
                } else {
                    amt.value = '0';
                    amt.disabled = true;
                }
                recalcTotal();
            }

            function remainingAvailable() {
                const pay = Number(amountInput.value) || 0;
                let used = 0;
                tbody.querySelectorAll('.alloc-amount').forEach(el => used += Number(el.value) || 0);
                return pay - used;
            }

            function recalcTotal() {
                let total = 0;
                tbody.querySelectorAll('.alloc-amount').forEach(el => total += Number(el.value) || 0);
                totalEl.textContent = fmt(total);
                const payAmount = Number(amountInput.value) || 0;
                const remainder = payAmount - total;
                remainderEl.textContent = fmt(remainder > 0 ? remainder : 0);
                if (total > payAmount + 0.001) {
                    totalEl.classList.add('text-danger');
                    remainderEl.classList.remove('text-muted');
                    remainderEl.classList.add('text-danger');
                    remainderEl.textContent = `Over by ${fmt(total - payAmount)}`;
                } else {
                    totalEl.classList.remove('text-danger');
                    remainderEl.classList.remove('text-danger');
                    remainderEl.classList.add('text-muted');
                }
            }

            function autoAllocate() {
                let remaining = Number(amountInput.value) || 0;
                tbody.querySelectorAll('tr[data-row]').forEach((tr) => {
                    const i = Number(tr.dataset.row);
                    const check = tr.querySelector('.alloc-check');
                    const amt = tr.querySelector('.alloc-amount');
                    const apply = Math.min(charges[i].balance, Math.max(0, remaining));
                    if (apply > 0) {
                        check.checked = true;
                        amt.disabled = false;
                        amt.value = apply.toFixed(2);
                        remaining -= apply;
                    } else {
                        check.checked = false;
                        amt.disabled = true;
                        amt.value = '0';
                    }
                });
                recalcTotal();
                if (charges.length) {
                    PPS.toast.info(`Auto-allocated ${fmt((Number(amountInput.value) || 0) - remaining)} across ${charges.length} bill(s).`);
                }
            }

            function selectAll(checked) {
                tbody.querySelectorAll('.alloc-check').forEach(c => {
                    c.checked = checked;
                    c.dispatchEvent(new Event('change'));
                });
            }

            async function loadOutstanding(leaseId) {
                if (!leaseId) { charges = []; renderTable(); return; }
                try {
                    const res = await fetch(`/api/leases/${leaseId}/outstanding-charges`, { credentials: 'same-origin' });
                    if (!res.ok) {
                        PPS.toast.error('Could not load outstanding bills.');
                        charges = []; renderTable();
                        return;
                    }
                    charges = await res.json();
                    renderTable();
                    if (Number(amountInput.value) > 0) autoAllocate();
                } catch {
                    PPS.toast.error('Network error loading bills.');
                    charges = []; renderTable();
                }
            }

            leaseSelect.addEventListener('change', () => loadOutstanding(leaseSelect.value));
            amountInput.addEventListener('input', recalcTotal);
            autoBtn.addEventListener('click', autoAllocate);
            selectAllBtn.addEventListener('click', () => selectAll(true));
            clearAllBtn.addEventListener('click', () => selectAll(false));

            form.addEventListener('submit', (e) => {
                let total = 0;
                tbody.querySelectorAll('.alloc-amount').forEach(el => total += Number(el.value) || 0);
                const pay = Number(amountInput.value) || 0;
                if (total > pay + 0.001) {
                    e.preventDefault();
                    PPS.toast.error(`Allocated ${fmt(total)} exceeds payment amount ${fmt(pay)}. Adjust before saving.`);
                }
            });

            if (leaseSelect.value) loadOutstanding(leaseSelect.value);
        })();
    </script>
}
