@page "{id:int}"
@model PropertyPayPro.Pages.Payments.EditModel
@{
    ViewData["Title"] = "Edit Payment";
}

<h1 class="h3 mb-3">Edit Payment</h1>

<div class="row">
    <div class="col-md-10">
        <form method="post" id="paymentForm">
            <input type="hidden" asp-for="Payment.Id" />

            <div class="card mb-3">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Payment.LeaseId" class="form-label">Lease</label>
                            <select asp-for="Payment.LeaseId" class="form-select" asp-items="Model.Leases" id="leaseSelect"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Payment.PaidByTenantId" class="form-label">Paid by tenant</label>
                            <select asp-for="Payment.PaidByTenantId" class="form-select" id="paidByTenantSelect">
                                <option value="">(unspecified)</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Payment.PaidOn" class="form-label"></label>
                            <input asp-for="Payment.PaidOn" class="form-control" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Payment.Amount" class="form-label"></label>
                            <input asp-for="Payment.Amount" class="form-control" id="amountInput" step="0.01" min="0" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Payment.Method" class="form-label"></label>
                            <select asp-for="Payment.Method" class="form-select"
                                    asp-items="Html.GetEnumSelectList<PropertyPayPro.Models.PaymentMethod>()"></select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Payment.Reference" class="form-label"></label>
                        <input asp-for="Payment.Reference" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Payment.Notes" class="form-label"></label>
                        <textarea asp-for="Payment.Notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <h4 class="card-title mb-0">Allocate to bills</h4>
                </div>
                <div class="card-body">
                    @if (!Model.OutstandingCharges.Any())
                    {
                        <p class="text-muted mb-0">No outstanding bills for this lease. The payment is held as a credit.</p>
                    }
                    else
                    {
                        <p class="text-muted small">
                            Check a bill to apply funds. The total can be less than the payment amount;
                            the remainder is held as a credit.
                        </p>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th style="width: 2.5rem;"></th>
                                        <th>Period</th>
                                        <th>Due</th>
                                        <th class="text-end">Available</th>
                                        <th class="text-end" style="width: 10rem;">Apply</th>
                                    </tr>
                                </thead>
                                <tbody id="allocationTbody">
                                @for (int i = 0; i < Model.OutstandingCharges.Count; i++)
                                {
                                    var c = Model.OutstandingCharges[i];
                                    var current = Model.CurrentAllocations.TryGetValue(c.Id, out var v) ? v : 0m;
                                    var maxAllowed = c.Balance + current;
                                    var isChecked = current > 0;
                                    <tr data-row="@i">
                                        <td>
                                            <input type="checkbox" class="form-check-input alloc-check" data-row="@i" @(isChecked ? "checked" : "") />
                                        </td>
                                        <td>@c.PeriodLabel</td>
                                        <td>@c.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-end">@maxAllowed.ToString("C")</td>
                                        <td>
                                            <input type="hidden" name="AllocationChargeIds[@i]" value="@c.Id" />
                                            <input type="number" step="0.01" min="0" max="@maxAllowed"
                                                   name="AllocationAmounts[@i]" value="@current.ToString("0.00")"
                                                   data-row="@i" @(isChecked ? "" : "readonly")
                                                   class="form-control form-control-sm alloc-amount text-end" />
                                        </td>
                                    </tr>
                                }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th colspan="4" class="text-end">Total allocated</th>
                                        <th class="text-end" id="allocationTotal">$0.00</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save Payment</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const LEASE_TENANTS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LeaseTenants));
        const SELECTED_TENANT_ID = '@(Model.Payment.PaidByTenantId?.ToString() ?? "")';
    </script>
    <script>
        (function () {
            const leaseSelect = document.getElementById('leaseSelect');
            const paidBySelect = document.getElementById('paidByTenantSelect');
            const amountInput = document.getElementById('amountInput');
            const tbody = document.getElementById('allocationTbody');
            const totalEl = document.getElementById('allocationTotal');
            const form = document.getElementById('paymentForm');

            function refreshPaidByOptions(preserveSelection) {
                if (!paidBySelect || !leaseSelect) return;
                const leaseId = leaseSelect.value;
                const tenants = (LEASE_TENANTS[leaseId] || []);
                const current = preserveSelection ? (paidBySelect.value || SELECTED_TENANT_ID) : '';
                paidBySelect.innerHTML =
                    '<option value="">(unspecified)</option>' +
                    tenants.map(t => `<option value="${t.Id}" ${String(t.Id) === current ? 'selected' : ''}>${t.DisplayName}</option>`).join('');
            }
            if (leaseSelect) leaseSelect.addEventListener('change', () => refreshPaidByOptions(false));
            refreshPaidByOptions(true);

            if (!tbody) return;

            const fmt = n => '$' + (Number(n) || 0).toFixed(2);

            function recalc() {
                let total = 0;
                tbody.querySelectorAll('.alloc-amount').forEach(el => total += Number(el.value) || 0);
                totalEl.textContent = fmt(total);
                const pay = Number(amountInput.value) || 0;
                totalEl.classList.toggle('text-danger', total > pay + 0.001);
            }

            tbody.querySelectorAll('.alloc-check').forEach(c => c.addEventListener('change', e => {
                const i = e.target.dataset.row;
                const amt = tbody.querySelector(`.alloc-amount[data-row="${i}"]`);
                if (e.target.checked) {
                    amt.removeAttribute('readonly');
                    if (Number(amt.value) === 0) amt.value = amt.max;
                    amt.focus(); amt.select();
                } else {
                    amt.value = '0';
                    amt.setAttribute('readonly', '');
                }
                recalc();
            }));
            tbody.querySelectorAll('.alloc-amount').forEach(el => el.addEventListener('input', recalc));
            amountInput.addEventListener('input', recalc);

            form.addEventListener('submit', (e) => {
                let total = 0;
                tbody.querySelectorAll('.alloc-amount').forEach(el => total += Number(el.value) || 0);
                const pay = Number(amountInput.value) || 0;
                if (total > pay + 0.001) {
                    e.preventDefault();
                    PPS.toast.error(`Allocated ${fmt(total)} exceeds payment amount ${fmt(pay)}. Adjust before saving.`);
                }
            });

            recalc();
        })();
    </script>
}
