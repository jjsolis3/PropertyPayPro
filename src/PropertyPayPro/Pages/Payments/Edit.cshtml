@page "{id:int}"
@model PropertyPayPro.Pages.Payments.EditModel
@{
    ViewData["Title"] = "Edit Payment";
}

<h1>Edit Payment</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Payment.Id" />
            <div class="mb-3">
                <label asp-for="Payment.LeaseId" class="form-label">Lease</label>
                <select asp-for="Payment.LeaseId" class="form-select" asp-items="Model.Leases"></select>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Payment.PaidOn" class="form-label"></label>
                    <input asp-for="Payment.PaidOn" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Payment.Amount" class="form-label"></label>
                    <input asp-for="Payment.Amount" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Payment.Method" class="form-label"></label>
                    <select asp-for="Payment.Method" class="form-select"
                            asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Payment.Reference" class="form-label"></label>
                <input asp-for="Payment.Reference" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Payment.Notes" class="form-label"></label>
                <textarea asp-for="Payment.Notes" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
