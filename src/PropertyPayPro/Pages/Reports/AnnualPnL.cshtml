@page
@model PropertyPayPro.Pages.Reports.AnnualPnLModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = $"P&L {Model.Year}";
}

<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
    <h1 class="h3 mb-0">Annual Profit &amp; Loss</h1>
    <div>
        <button type="button" class="btn btn-outline-secondary" onclick="window.print()">Print</button>
        <a asp-page="AnnualPnL"
           asp-route-Year="@Model.Year"
           asp-route-PropertyId="@Model.PropertyId"
           asp-route-Compare="@Model.Compare"
           asp-route-export="csv"
           class="btn btn-outline-success">Export CSV</a>
    </div>
</div>

<div class="card mb-3 d-print-none">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Year</label>
                <input type="number" name="Year" value="@Model.Year" min="2000" max="2100" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Property</label>
                <select name="PropertyId" class="form-select">
                    <option value="">All properties</option>
                    @foreach (var p in Model.PropertyOptions)
                    {
                        <option value="@p.Id" selected="@(Model.PropertyId == p.Id)">@p.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3 form-check ms-3 mb-2">
                <input class="form-check-input" type="checkbox" name="Compare" value="true" id="compareToggle" @(Model.Compare ? "checked" : "") />
                <label class="form-check-label" for="compareToggle">Compare to previous year</label>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = $"Total Income {Model.Year}", Value = Model.This.TotalIncome.ToString("C"),
        Color = "success", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = $"Total Expenses {Model.Year}", Value = Model.This.TotalExpenses.ToString("C"),
        Color = "warning", Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = $"Net {Model.Year}", Value = Model.This.Net.ToString("C"),
        Color = Model.This.Net >= 0 ? "primary" : "danger",
        Icon = "flaticon-381-notepad" })" />
    @if (Model.Prev is not null)
    {
        var diff = Model.This.Net - Model.Prev.Net;
        <partial name="_KpiCard" model="@(new KpiCardModel {
            Label = $"vs {Model.Prev.Year} Net", Value = diff.ToString("C"),
            SubText = $"Prev: {Model.Prev.Net:C}",
            Color = diff >= 0 ? "info" : "danger",
            Icon = "flaticon-381-controls-3" })" />
    }
    else
    {
        <partial name="_KpiCard" model="@(new KpiCardModel {
            Label = "Compare", Value = "Toggle on",
            SubText = "to see year-over-year",
            Color = "info", Icon = "flaticon-381-controls-3" })" />
    }
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-header"><h4 class="card-title mb-0">Income — @Model.Year</h4></div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <tbody>
                        <tr><td>Rent collected</td><td class="text-end">@Model.This.RentIncome.ToString("C")</td></tr>
                        <tr><td>Late fees collected</td><td class="text-end">@Model.This.LateFeeIncome.ToString("C")</td></tr>
                        <tr><td>Reimbursements (pass-through)</td><td class="text-end">@Model.This.ReimbursementIncome.ToString("C")</td></tr>
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr><td>Total income</td><td class="text-end">@Model.This.TotalIncome.ToString("C")</td></tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h4 class="card-title mb-0">Expenses — @Model.Year</h4></div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <tbody>
                    @foreach (var c in Model.This.ExpensesByCategory)
                    {
                        <tr><td>@c.Label</td><td class="text-end">@c.Amount.ToString("C")</td></tr>
                    }
                    @if (Model.This.RepairsExpense > 0)
                    {
                        <tr><td>Repairs / Service tickets</td><td class="text-end">@Model.This.RepairsExpense.ToString("C")</td></tr>
                    }
                    @if (!Model.This.ExpensesByCategory.Any() && Model.This.RepairsExpense == 0)
                    {
                        <tr><td colspan="2" class="text-center text-muted">No expenses recorded.</td></tr>
                    }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr><td>Total expenses</td><td class="text-end">@Model.This.TotalExpenses.ToString("C")</td></tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <h4 class="mb-0">Net @Model.Year</h4>
                    <h4 class="mb-0 @(Model.This.Net >= 0 ? "text-success" : "text-danger")">
                        @Model.This.Net.ToString("C")
                    </h4>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Prev is not null)
    {
        <div class="col-lg-6">
            <div class="card mb-3">
                <div class="card-header"><h4 class="card-title mb-0">Income — @Model.Prev.Year</h4></div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <tbody>
                            <tr><td>Rent collected</td><td class="text-end">@Model.Prev.RentIncome.ToString("C")</td></tr>
                            <tr><td>Late fees collected</td><td class="text-end">@Model.Prev.LateFeeIncome.ToString("C")</td></tr>
                            <tr><td>Reimbursements</td><td class="text-end">@Model.Prev.ReimbursementIncome.ToString("C")</td></tr>
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr><td>Total</td><td class="text-end">@Model.Prev.TotalIncome.ToString("C")</td></tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h4 class="card-title mb-0">Expenses — @Model.Prev.Year</h4></div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <tbody>
                        @foreach (var c in Model.Prev.ExpensesByCategory)
                        {
                            <tr><td>@c.Label</td><td class="text-end">@c.Amount.ToString("C")</td></tr>
                        }
                        @if (Model.Prev.RepairsExpense > 0)
                        {
                            <tr><td>Repairs</td><td class="text-end">@Model.Prev.RepairsExpense.ToString("C")</td></tr>
                        }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr><td>Total</td><td class="text-end">@Model.Prev.TotalExpenses.ToString("C")</td></tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h4 class="mb-0">Net @Model.Prev.Year</h4>
                        <h4 class="mb-0 @(Model.Prev.Net >= 0 ? "text-success" : "text-danger")">
                            @Model.Prev.Net.ToString("C")
                        </h4>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    @@media print {
        nav, footer, .d-print-none, .deznav, .header { display: none !important; }
        .content-body { margin-left: 0 !important; }
        .card { border: 1px solid #dee2e6 !important; }
    }
</style>
