@page
@model PropertyPayPro.Pages.Reports.UnpaidBillsModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "Unpaid Bills";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Unpaid Bills</h1>
        <p class="text-muted mb-0">Outstanding rent across all leases. Select tenants and email statements.</p>
    </div>
</div>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">
        @msg
        @if (TempData["Details"] is string details)
        {
            <div class="small mt-1">@details</div>
        }
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @err
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Leases with Balance", Value = Model.Groups.Count.ToString(),
        Color = "primary", Icon = "flaticon-381-notepad" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Unpaid Bills", Value = Model.TotalUnpaidBills.ToString(),
        Color = "warning", Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Total Outstanding", Value = Model.GrandTotal.ToString("C"),
        Color = "danger", Icon = "flaticon-381-warning" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Eligible for Email", Value = Model.EligibleForEmail.ToString(),
        SubText = "Tenants with email + reminders on",
        Color = "info", Icon = "flaticon-381-controls-3" })" />
</div>

@if (!Model.MailConfigured)
{
    <div class="alert alert-warning">
        <strong>SMTP is not configured.</strong> Set <code>SMTP_HOST</code>, <code>SMTP_USER</code>,
        <code>SMTP_PASSWORD</code>, and <code>SMTP_FROM</code> in your environment to enable emailing.
    </div>
}

<form method="post" asp-page-handler="Send" id="bulkForm">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-primary" id="selectAllBtn">Select All</button>
                <button type="button" class="btn btn-outline-success" id="selectEligibleBtn">Select Email-Eligible</button>
                <button type="button" class="btn btn-outline-secondary" id="clearAllBtn">Clear</button>
            </div>
            @if (Model.MailConfigured)
            {
                <button type="submit" class="btn btn-primary" id="sendBtn"
                        onclick="return confirm('Email statements to selected tenants?');">
                    <i class="las la-envelope"></i> Email Statements to Selected
                </button>
            }
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 2.5rem;"></th>
                            <th>Tenant(s)</th>
                            <th>Property</th>
                            <th class="text-center"># Unpaid</th>
                            <th>Oldest Due</th>
                            <th class="text-end">Total Balance</th>
                            <th>Last Statement</th>
                            <th>Email Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var g in Model.Groups)
                    {
                        var rowClass = g.MostOverdueDays > 60 ? "table-danger" : g.MostOverdueDays > 30 ? "table-warning" : "";
                        <tr class="@rowClass">
                            <td>
                                <input type="checkbox" class="form-check-input lease-check"
                                       name="selectedLeaseIds" value="@g.LeaseId"
                                       data-eligible="@(g.HasEmailEligibleTenant ? "1" : "0")" />
                            </td>
                            <td>
                                <div class="fw-semibold">@g.TenantNames</div>
                                @if (!string.IsNullOrWhiteSpace(g.EligibleEmail))
                                {
                                    <small class="text-muted">@g.EligibleEmail</small>
                                }
                            </td>
                            <td>@g.PropertyName</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-link btn-sm p-0"
                                        data-bs-toggle="collapse" data-bs-target="#bills-@g.LeaseId">
                                    @g.UnpaidBills.Count
                                </button>
                            </td>
                            <td>
                                @g.OldestDueDate.ToString("yyyy-MM-dd")
                                @if (g.MostOverdueDays > 0)
                                {
                                    <span class="badge bg-danger ms-1">@g.MostOverdueDays d overdue</span>
                                }
                            </td>
                            <td class="text-end fw-bold">@g.TotalBalance.ToString("C")</td>
                            <td>
                                @if (g.LastStatementSentUtc.HasValue)
                                {
                                    <span class="text-muted small">@g.LastStatementSentUtc.Value.ToLocalTime().ToString("yyyy-MM-dd")</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Never</span>
                                }
                            </td>
                            <td>
                                @if (g.HasEmailEligibleTenant)
                                {
                                    <span class="badge bg-success">Ready</span>
                                }
                                else if (!g.AnyTenantHasEmail)
                                {
                                    <span class="badge bg-secondary" title="No tenant has an email on file">No email</span>
                                }
                                else if (g.AnyTenantOptedOut)
                                {
                                    <span class="badge bg-warning text-dark" title="Tenant opted out of reminders">Opted out</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">N/A</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="/Reports/Statement" asp-route-leaseId="@g.LeaseId"
                                   class="btn btn-sm btn-outline-secondary">View</a>
                            </td>
                        </tr>
                        <tr class="collapse" id="bills-@g.LeaseId">
                            <td colspan="9" class="bg-light">
                                <table class="table table-sm mb-0">
                                    <thead>
                                        <tr>
                                            <th>Invoice #</th>
                                            <th>Period</th>
                                            <th>Due Date</th>
                                            <th class="text-end">Amount Due</th>
                                            <th class="text-end">Paid</th>
                                            <th class="text-end">Balance</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var c in g.UnpaidBills)
                                    {
                                        <tr>
                                            <td>@c.Id.ToString("D8")</td>
                                            <td>@c.PeriodLabel</td>
                                            <td>@c.DueDate.ToString("yyyy-MM-dd")</td>
                                            <td class="text-end">@c.AmountDue.ToString("C")</td>
                                            <td class="text-end">@c.AmountPaid.ToString("C")</td>
                                            <td class="text-end fw-bold">@c.Balance.ToString("C")</td>
                                            <td>
                                                @switch (c.Status)
                                                {
                                                    case PropertyPayPro.Models.ChargeStatus.Overdue:
                                                        <span class="badge bg-danger">Overdue</span>
                                                        break;
                                                    case PropertyPayPro.Models.ChargeStatus.PartiallyPaid:
                                                        <span class="badge bg-warning text-dark">Partial</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">Unpaid</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    }
                    @if (!Model.Groups.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">
                            No unpaid bills. Everyone is current.
                        </td></tr>
                    }
                    </tbody>
                    @if (Model.Groups.Any())
                    {
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="5" class="text-end">Grand Total</td>
                                <td class="text-end text-danger">@Model.GrandTotal.ToString("C")</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            const all = () => document.querySelectorAll('.lease-check');
            document.getElementById('selectAllBtn')?.addEventListener('click', () =>
                all().forEach(c => c.checked = true));
            document.getElementById('clearAllBtn')?.addEventListener('click', () =>
                all().forEach(c => c.checked = false));
            document.getElementById('selectEligibleBtn')?.addEventListener('click', () =>
                all().forEach(c => c.checked = c.dataset.eligible === '1'));

            const form = document.getElementById('bulkForm');
            form?.addEventListener('submit', (e) => {
                const checked = document.querySelectorAll('.lease-check:checked').length;
                if (checked === 0) {
                    e.preventDefault();
                    PPS.toast.error('Select at least one tenant before sending.');
                }
            });
        })();
    </script>
}
