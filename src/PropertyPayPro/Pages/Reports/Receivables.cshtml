@page
@model PropertyPayPro.Pages.Reports.ReceivablesModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "Receivables Summary";
}

<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
    <h1 class="h3 mb-0">Receivables Summary</h1>
    <div>
        <button type="button" class="btn btn-outline-secondary" onclick="window.print()">Print</button>
        <a asp-page="Receivables"
           asp-route-FromDate="@Model.FromDate"
           asp-route-ToDate="@Model.ToDate"
           asp-route-PropertyId="@Model.PropertyId"
           asp-route-export="csv"
           class="btn btn-outline-success">Export CSV</a>
    </div>
</div>

<div class="card mb-3 d-print-none">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">From</label>
                <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To</label>
                <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Property</label>
                <select name="PropertyId" class="form-select">
                    <option value="">All properties</option>
                    @foreach (var p in Model.PropertyOptions)
                    {
                        <option value="@p.Id" selected="@(Model.PropertyId == p.Id)">@p.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-page="Receivables" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Billed (in range)", Value = Model.TotalBilled.ToString("C"),
        Color = "primary", Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Collected (in range)", Value = Model.TotalCollected.ToString("C"),
        Color = "success", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Outstanding (all)", Value = Model.TotalOutstanding.ToString("C"),
        Color = "warning", Icon = "flaticon-381-warning" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "On-time %", Value = $"{Model.OnTimePercent}%",
        SubText = "Of paid bills in range",
        Color = "info", Icon = "flaticon-381-time" })" />
</div>

<div class="card mb-3">
    <div class="card-header"><h4 class="card-title mb-0">Aging</h4></div>
    <div class="card-body">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Current</th>
                    <th>1–30</th>
                    <th>31–60</th>
                    <th>61–90</th>
                    <th>90+</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.Aging.Current.ToString("C")</td>
                    <td>@Model.Aging.D1_30.ToString("C")</td>
                    <td>@Model.Aging.D31_60.ToString("C")</td>
                    <td>@Model.Aging.D61_90.ToString("C")</td>
                    <td class="@(Model.Aging.D90Plus > 0 ? "text-danger fw-bold" : "")">@Model.Aging.D90Plus.ToString("C")</td>
                    <td class="text-end fw-bold">@Model.Aging.Total.ToString("C")</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="card">
    <div class="card-header"><h4 class="card-title mb-0">By Lease</h4></div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Tenants</th>
                        <th class="text-end">Billed</th>
                        <th class="text-end">Collected</th>
                        <th class="text-end">Outstanding</th>
                        <th class="d-print-none"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.LeaseRows)
                {
                    <tr>
                        <td>@r.PropertyName</td>
                        <td>@r.TenantNames</td>
                        <td class="text-end">@r.Billed.ToString("C")</td>
                        <td class="text-end">@r.Collected.ToString("C")</td>
                        <td class="text-end @(r.Outstanding > 0 ? "fw-bold" : "")">@r.Outstanding.ToString("C")</td>
                        <td class="text-end d-print-none">
                            <a asp-page="/Leases/Details" asp-route-id="@r.LeaseId" class="btn btn-sm btn-outline-secondary">View</a>
                        </td>
                    </tr>
                }
                @if (!Model.LeaseRows.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No data for the selected filters.</td></tr>
                }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td colspan="2" class="text-end">Totals</td>
                        <td class="text-end">@Model.LeaseRows.Sum(r => r.Billed).ToString("C")</td>
                        <td class="text-end">@Model.LeaseRows.Sum(r => r.Collected).ToString("C")</td>
                        <td class="text-end">@Model.LeaseRows.Sum(r => r.Outstanding).ToString("C")</td>
                        <td class="d-print-none"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<style>
    @@media print {
        nav, footer, .d-print-none, .deznav, .header { display: none !important; }
        .content-body { margin-left: 0 !important; }
        .card { border: 1px solid #dee2e6 !important; }
    }
</style>
