@page "{id:int}"
@model PropertyPayPro.Pages.Properties.DetailsModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = Model.Property!.Name;
    var address = Model.Property.AddressLine1
        + (string.IsNullOrWhiteSpace(Model.Property.AddressLine2) ? "" : ", " + Model.Property.AddressLine2)
        + $", {Model.Property.City}, {Model.Property.State} {Model.Property.PostalCode}";
    var badges = new List<DetailHeaderBadge>();
    if (Model.ActiveLeases.Count > 0)
        badges.Add(new() { Text = $"{Model.ActiveLeases.Count} active lease(s)", Color = "success" });
    else
        badges.Add(new() { Text = "Vacant", Color = "warning" });
    if (Model.Outstanding > 0)
        badges.Add(new() { Text = $"Outstanding: {Model.Outstanding:C}", Color = "danger" });
    if (Model.OpenTickets.Count > 0)
        badges.Add(new() { Text = $"{Model.OpenTickets.Count} open ticket(s)", Color = "info" });
}

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap align-items-center gap-3">
        <div class="flex-grow-1">
            <partial name="_DetailHeader" model="@(new DetailHeaderModel {
                Title = Model.Property.Name,
                Subtitle = address,
                IconClass = "flaticon-381-home-2",
                IconColor = "primary",
                Badges = badges
            })" />
        </div>
        <div class="flex-shrink-0">
            <a asp-page="Edit" asp-route-id="@Model.Property.Id" class="btn btn-primary">Edit</a>
            <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Monthly Rent Roll", Value = Model.MonthlyRentRoll.ToString("C"),
        Color = "primary", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Outstanding", Value = Model.Outstanding.ToString("C"),
        SubText = $"{Model.UnpaidBills.Count} bill(s)",
        Color = Model.Outstanding > 0 ? "danger" : "success",
        Icon = "flaticon-381-list" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Collected YTD", Value = Model.CollectedYearToDate.ToString("C"),
        Color = "success", Icon = "flaticon-381-notepad" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Spent YTD", Value = Model.SpentYearToDate.ToString("C"),
        SubText = "Property expenses",
        Color = "info", Icon = "flaticon-381-briefcase" })" />
</div>

<div class="card">
    <div class="card-body p-0">
        <ul class="nav nav-tabs nav-fill" id="propertyTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-overview" type="button" role="tab">Overview</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-leases" type="button" role="tab">
                    Leases <span class="badge bg-secondary ms-1">@Model.Leases.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-bills" type="button" role="tab">
                    Outstanding Bills <span class="badge @(Model.UnpaidBills.Count > 0 ? "bg-danger" : "bg-success") ms-1">@Model.UnpaidBills.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-expenses" type="button" role="tab">
                    Expenses <span class="badge bg-secondary ms-1">@Model.RecentExpenses.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-tickets" type="button" role="tab">
                    Service Tickets <span class="badge @(Model.OpenTickets.Count > 0 ? "bg-warning" : "bg-secondary") ms-1">@Model.OpenTickets.Count</span>
                </button>
            </li>
        </ul>

        <div class="tab-content p-3">
            <div class="tab-pane fade show active" id="tab-overview" role="tabpanel">
                <h5 class="mb-3">Property Details</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Address</dt>
                    <dd class="col-sm-9">@address</dd>
                    <dt class="col-sm-3">Active leases</dt>
                    <dd class="col-sm-9">@Model.ActiveLeases.Count of @Model.Leases.Count total</dd>
                    <dt class="col-sm-3">Monthly rent roll</dt>
                    <dd class="col-sm-9">@Model.MonthlyRentRoll.ToString("C")</dd>
                    @if (!string.IsNullOrWhiteSpace(Model.Property.Notes))
                    {
                        <dt class="col-sm-3">Notes</dt>
                        <dd class="col-sm-9">@Model.Property.Notes</dd>
                    }
                </dl>
            </div>

            <div class="tab-pane fade" id="tab-leases" role="tabpanel">
                <h5 class="mb-2">Leases</h5>
                <div class="table-responsive">
                    <table class="table mb-0 js-datatable" data-order='[[1,"desc"]]' data-page-length="10">
                        <thead class="table-light">
                            <tr><th>Tenant(s)</th><th>Term</th><th class="text-end">Monthly</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                        @foreach (var l in Model.Leases)
                        {
                            var today = DateOnly.FromDateTime(DateTime.UtcNow);
                            var isActive = l.StartDate <= today && (l.IsMonthToMonth || l.EndDate >= today);
                            <tr>
                                <td>@l.TenantNames</td>
                                <td>
                                    @l.StartDate.ToString("yyyy-MM-dd") →
                                    @(l.IsMonthToMonth ? "M2M" : l.EndDate.ToString("yyyy-MM-dd"))
                                </td>
                                <td class="text-end">@l.MonthlyRent.ToString("C")</td>
                                <td>
                                    @if (isActive) { <span class="badge bg-success">Active</span> }
                                    else { <span class="badge bg-secondary">Ended</span> }
                                </td>
                                <td class="text-end">
                                    <a asp-page="/Leases/Details" asp-route-id="@l.Id" class="btn btn-sm btn-outline-secondary">View</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-bills" role="tabpanel">
                <h5 class="mb-2">Outstanding Bills</h5>
                <div class="table-responsive">
                    <table class="table mb-0 js-datatable" data-order='[[1,"asc"]]' data-page-length="10">
                        <thead class="table-light"><tr><th>Tenant</th><th>Period</th><th class="text-end">Balance</th></tr></thead>
                        <tbody>
                        @foreach (var c in Model.UnpaidBills)
                        {
                            <tr>
                                <td>@c.Lease?.TenantNames</td>
                                <td>@c.BillingPeriodStart.ToString("MMM yyyy")</td>
                                <td class="text-end fw-bold">@c.Balance.ToString("C")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-expenses" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Recent Expenses</h5>
                    <a asp-page="/Expenses/Index" class="btn btn-sm btn-outline-primary">All expenses</a>
                </div>
                <div class="table-responsive">
                    <table class="table mb-0 js-datatable" data-order='[[3,"desc"]]' data-page-length="10">
                        <thead class="table-light">
                            <tr><th>Category</th><th>Description</th><th>Vendor</th><th>Due</th><th>Paid</th><th class="text-end">Amount</th></tr>
                        </thead>
                        <tbody>
                        @foreach (var e in Model.RecentExpenses)
                        {
                            <tr>
                                <td>@e.Category</td>
                                <td>@e.Description</td>
                                <td>@e.Vendor</td>
                                <td>@(e.DueDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td>@(e.PaidOn?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td class="text-end">@e.AmountDue.ToString("C")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-tickets" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Open Service Tickets</h5>
                    <a asp-page="/ServiceTickets/Create" class="btn btn-sm btn-outline-success">New</a>
                </div>
                <div class="table-responsive">
                    <table class="table mb-0 js-datatable" data-order='[[2,"asc"]]' data-page-length="10">
                        <thead class="table-light"><tr><th>Title</th><th>Category</th><th>Status</th></tr></thead>
                        <tbody>
                        @foreach (var t in Model.OpenTickets)
                        {
                            <tr>
                                <td>
                                    <a asp-page="/ServiceTickets/Details" asp-route-id="@t.Id">@t.Title</a>
                                </td>
                                <td>@t.Category</td>
                                <td>
                                    @if (t.Status == PropertyPayPro.Models.ServiceTicketStatus.InProgress)
                                    { <span class="badge bg-info">In progress</span> }
                                    else
                                    { <span class="badge bg-warning text-dark">Open</span> }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
