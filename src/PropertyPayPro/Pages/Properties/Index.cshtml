@page
@model PropertyPayPro.Pages.Properties.IndexModel
@using PropertyPayPro.Pages.Shared
@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Properties</h1>
    <a asp-page="Create" class="btn btn-success">New Property</a>
</div>

<div class="row">
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Total Properties", Value = Model.TotalCount.ToString(),
        Color = "primary", Icon = "flaticon-381-home-2" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Occupied / Vacant",
        Value = $"{Model.OccupiedCount} / {Model.VacantCount}",
        SubText = Model.TotalCount > 0 ? $"{(Model.OccupiedCount * 100 / Math.Max(Model.TotalCount, 1))}% occupied" : null,
        Color = "success", Icon = "flaticon-381-notepad" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Monthly Rent Roll", Value = Model.RentRoll.ToString("C"),
        Color = "info", Icon = "las la-dollar-sign" })" />
    <partial name="_KpiCard" model="@(new KpiCardModel {
        Label = "Outstanding", Value = Model.Outstanding.ToString("C"),
        Color = "warning", Icon = "flaticon-381-list",
        LinkPage = "/Bills/Index", LinkText = "View bills" })" />
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped mb-0 js-datatable" data-order='[[0,"asc"]]'>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Address</th>
                    <th>City</th>
                    <th>State</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Properties)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.AddressLine1</td>
                    <td>@item.City</td>
                    <td>@item.State</td>
                    <td class="text-end">
                        <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            @if (!Model.Properties.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-3">No properties yet. Click <strong>New Property</strong> to add one.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
