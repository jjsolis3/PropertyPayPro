@page "{id:int}"
@model PropertyPayPro.Pages.Properties.DeleteModel
@{
    ViewData["Title"] = "Delete Property";
}

<h1 class="text-danger">Delete Property</h1>
<p>Are you sure you want to delete <strong>@Model.Property!.Name</strong>?</p>

<form method="post">
    <input type="hidden" asp-for="Property.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
