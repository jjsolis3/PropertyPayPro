@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<div class="text-center">
    <h1 class="h3 text-danger mb-3">Access denied</h1>
    <p class="text-muted">
        You're signed in as <strong>@Model.CurrentEmail</strong>, but this account doesn't have
        permission to view the page you tried to reach.
    </p>

    @if (Model.IsTenantWithoutPortal)
    {
        <div class="alert alert-info small mt-3 mb-4">
            The tenant portal is not yet available. Please contact your property manager.
        </div>
    }
    else if (Model.HasNoRole)
    {
        <div class="alert alert-info small mt-3 mb-4">
            No role is assigned to this account. Please contact an administrator to grant you the
            access you need.
        </div>
    }

    <form method="post" asp-page-handler="Logout" class="d-grid mt-4">
        <button type="submit" class="btn btn-primary">Sign out</button>
    </form>
    <div class="mt-3">
        <a asp-page="/Account/Login" class="text-decoration-none">Back to login</a>
    </div>
</div>
