@page
@model IndexModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="form-head mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="text-black font-w600 mb-0">My Profile</h2>
        <p class="text-muted mb-0">Update your name, contact info, and avatar.</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-xl-4">
        <div class="card">
            <div class="card-body text-center">
                @{
                    var hasAvatar = !string.IsNullOrWhiteSpace(Model.AvatarStorageKey);
                    var initials = string.Concat(Model.CurrentDisplayName
                        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                        .Take(2).Select(s => char.ToUpper(s[0])));
                }
                @if (hasAvatar)
                {
                    <img src="@Url.Page("./Avatar")" alt="Avatar"
                         class="rounded-circle mb-3"
                         style="width: 140px; height: 140px; object-fit: cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3 fw-bold"
                         style="width: 140px; height: 140px; font-size: 3rem;">@initials</div>
                }
                <h4 class="mb-1">@Model.CurrentDisplayName</h4>
                <p class="text-muted">@Model.Email</p>

                <form method="post" asp-page-handler="UploadAvatar" enctype="multipart/form-data" class="mt-3">
                    <div class="mb-2">
                        <input type="file" name="avatar" accept="image/*" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">Upload new avatar</button>
                    @if (hasAvatar)
                    {
                        <button type="submit" asp-page-handler="RemoveAvatar" class="btn btn-sm btn-outline-danger ms-2"
                                formnovalidate
                                onclick="return confirm('Remove avatar?')">Remove</button>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Account details</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Input.FirstName" class="form-label"></label>
                            <input asp-for="Input.FirstName" class="form-control" />
                            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Input.LastName" class="form-label"></label>
                            <input asp-for="Input.LastName" class="form-control" />
                            <span asp-validation-for="Input.LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input value="@Model.Email" class="form-control" disabled />
                        <small class="text-muted">Email changes are managed under Email in the side menu.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.PhoneNumber" class="form-label"></label>
                        <input asp-for="Input.PhoneNumber" class="form-control" />
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>

                    <button id="update-profile-button" type="submit" class="btn btn-primary">Save changes</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
